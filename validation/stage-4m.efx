--- STAGE 4m ---

// Identifiers of tenders for a lot that is not for a framework agreement
LET text* : $global-ten-no-fa = OPT-320-LotResult[(BT-13713-LotResult in BT-137-Lot[BT-765-Lot not in ['fa-mix','fa-w-rc','fa-wo-rc']])]:rawValue;

// Identifiers of tenders for a lot that is for a framework agreement
LET text* : $global-ten-fa = OPT-320-LotResult[(BT-13713-LotResult in BT-137-Lot[BT-765-Lot in ['fa-mix','fa-w-rc','fa-wo-rc']])]:rawValue;

// Identifiers of tenders that have been selected and the corresponding lot is not for a framework agreement
LET text* : $global-ten-selec-no-fa = OPT-320-LotResult[(BT-142-LotResult == 'selec-w') and (BT-13713-LotResult in BT-137-Lot[BT-765-Lot not in ['fa-mix','fa-w-rc','fa-wo-rc']])]:rawValue;

// Identifiers of tenders that have been selected and the corresponding lot is for a framework agreement
LET text* : $global-ten-selec-fa = OPT-320-LotResult[(BT-142-LotResult == 'selec-w') and (BT-13713-LotResult in BT-137-Lot[BT-765-Lot in ['fa-mix','fa-w-rc','fa-wo-rc']])]:rawValue;

// Identifiers of tenders that led to contracts within a framework agreement
LET text* : $global-ten-contract-in-fa = BT-3202-Contract[BT-768-Contract == TRUE]:rawValue;

// Identifiers of tenders that are in a result for which the competition is ongoing
LET text* : $global-ten-ongoing = OPT-320-LotResult[BT-142-LotResult == 'open-nw']:rawValue;

// Identifiers of tenders that are in a result for which the competition is closed with no winner
LET text* : $global-ten-clos-nw = OPT-320-LotResult[BT-142-LotResult == 'clos-nw']:rawValue;

// Identifiers of tendering parties that have submitted a tender that is referenced in a contract
LET text* : $global-tpa-winner = OPT-310-Tender[OPT-321-Tender in BT-3202-Contract]:rawValue;

// Identifiers of organisations that are part of a tendering party that has submitted a tender that is referenced in a contract
LET text* : $global-org-winner = OPT-300-Tenderer[OPT-210-Tenderer in $global-tpa-winner]:rawValue;

// Identifiers of organisations that are subcontractors in a tendering party that has submitted a tender that is referenced in a contract
LET text* : $global-org-winner-subcontractor = OPT-301-Tenderer-SubCont[OPT-210-Tenderer in $global-tpa-winner]:rawValue;

WITH ND-LotTender
  WHEN OPT-321-Tender in $global-ten-clos-nw
  ASSERT BT-193-Tender is not present
    AS ERROR R-UX9-G3Z
    FOR BT-193-Tender
    IN 29-37,E4,E5
  WHEN not(OPT-321-Tender in $global-ten-clos-nw)
  ASSERT BT-193-Tender is present
    AS ERROR R-RXE-7FY
    FOR BT-193-Tender
    IN 30

  WHEN OPT-321-Tender in $global-ten-ongoing
  ASSERT BT-720-Tender is not present
    AS ERROR R-ITV-OQC // BR-BT-00720-0052
    FOR BT-720-Tender
    IN 29-35,E4

  WHEN (OPT-321-Tender in $global-ten-selec-no-fa) or (OPT-321-Tender in $global-ten-selec-fa and OPT-321-Tender in $global-ten-contract-in-fa)
  ASSERT BT-720-Tender is present
    AS ERROR R-BEJ-XAH // BR-BT-00720-0036
    FOR BT-720-Tender
    IN 29-35

  WHEN (OPT-321-Tender in $global-ten-no-fa) or (OPT-321-Tender in $global-ten-fa and OPT-321-Tender in $global-ten-contract-in-fa)
  ASSERT BT-720-Tender is present
    AS ERROR R-R72-91M // BR-BT-00720-0047
    FOR BT-720-Tender
    IN 38,39,E6

WITH ND-Company
  WHEN (OPT-200-Organization-Company in $global-org-winner) or (OPT-200-Organization-Company in $global-org-winner-subcontractor)
  ASSERT BT-165-Organization-Company is present
    AS ERROR R-VSP-FAU // BR-BT-00165-0036
    FOR BT-165-Organization-Company
    IN 29,30,32-37    
