  ASSERT ((((1.00 >= sum(BT-752-Lot-WeightNumber[BT-7531-Lot == 'dec-exa']))) and ((1.00 - sum(BT-752-Lot-WeightNumber[BT-7531-Lot == 'dec-exa'])) <= (0.01 * count(BT-752-Lot-WeightNumber[BT-7531-Lot == 'dec-exa'])))) or (((1.00 <= sum(BT-752-Lot-WeightNumber[BT-7531-Lot == 'dec-exa']))) and ((sum(BT-752-Lot-WeightNumber[BT-7531-Lot == 'dec-exa']) - 1.00) <= (0.01 * count(BT-752-Lot-WeightNumber[BT-7531-Lot == 'dec-exa']))))) or not(BT-752-Lot-WeightNumber[BT-7531-Lot == 'dec-exa'] is present)
