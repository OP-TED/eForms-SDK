WITH ND-NoticeResult
  WHEN BT-1118-NoticeResult is present
  ASSERT (not(BT-1561-NoticeResult is present) and (every text:$faEstCurr in (BT-660-LotResult/@currencyID) satisfies $faEstCurr == BT-1118-NoticeResult/@currencyID) and (((BT-1118-NoticeResult >= sum(BT-660-LotResult)) and ((BT-1118-NoticeResult - sum(BT-660-LotResult)) <= (1.00 * count(BT-660-LotResult)))) or ((BT-1118-NoticeResult <= sum(BT-660-LotResult)) and ((sum(BT-660-LotResult) - BT-1118-NoticeResult) <= (1.00 * count(BT-660-LotResult)))))) or (BT-1561-NoticeResult is present) or not(every text:$faEst in (BT-660-LotResult/@currencyID) satisfies $faEst == BT-1118-NoticeResult/@currencyID)
    AS ERROR R-4FB-BWG
