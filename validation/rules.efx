    AS ERROR R-W79-U40
    FOR OPT-301-Tenderer-SubCont
    IN *
  WHEN OPT-301-Tenderer-SubCont is present
  ASSERT every text:$employ in /OPT-301-Lot-EmployLegis satisfies $employ not in OPT-301-Tenderer-SubCont
    AS ERROR R-8ZP-7DH
    FOR OPT-301-Tenderer-SubCont
    IN *
  WHEN OPT-301-Tenderer-SubCont is present
