    AS ERROR R-Z9Q-87F
    FOR BT-539-LotsGroup
    IN *
  WHEN BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'ord-imp'] is present
  ASSERT every number:$ordImp in BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'ord-imp'] satisfies ($ordImp % 1 == 0)
    AS ERROR R-LSQ-KB2
    FOR BT-539-LotsGroup
    IN *
  WHEN BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'ord-imp'] is present
  ASSERT every number:$ordImp in BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'ord-imp'] satisfies($ordImp <= count(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'ord-imp']))
    AS ERROR R-SSR-MQA
    FOR BT-539-LotsGroup
    IN *
  ASSERT ((((1.00 >= sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'dec-exa']))) and ((1.00 - sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'dec-exa'])) <= (0.01 * count(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'dec-exa'])))) or (((1.00 <= sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'dec-exa']))) and ((sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'dec-exa']) - 1.00) <= (0.01 * count(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'dec-exa']))))) or not(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'dec-exa'] is present)
    AS ERROR R-XVB-7HS
    FOR BT-543-LotsGroup
    IN *
  ASSERT ((((100 >= sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'per-exa']))) and ((100 - sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'per-exa'])) <= (1.00 * count(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'per-exa'])))) or (((100 <= sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'per-exa']))) and ((sum(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'per-exa']) - 100) <= (1.00 * count(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'per-exa']))))) or not(BT-541-LotsGroup-WeightNumber[BT-5421-LotsGroup == 'per-exa'] is present)
