    FOR BT-1118-NoticeResult
    IN 25,26,27
  WHEN not(not(some text:$x in BT-142-LotResult[BT-13713-LotResult in BT-137-Lot[BT-765-Lot in ['fa-mix','fa-w-rc','fa-wo-rc']]] satisfies $x == 'selec-w') or (BT-660-LotResult is not present))
