WITH ND-BuyerReviewComplainants
  WHEN BT-712(b)-LotResult is present
  ASSERT ((BT-144-LotResult == 'rev-buyer') and (BT-712(b)-LotResult > 0)) or not(BT-144-LotResult == 'rev-buyer')
    AS ERROR R-CIQ-UGM
    FOR BT-712(b)-LotResult
    IN *

WITH ND-Company
  WHEN (OPT-200-Organization-Company in OPT-300-Procedure-Buyer)
  ASSERT (BT-514-Organization-Company[OPT-200-Organization-Company in OPT-300-Procedure-Buyer] in #lawful-country)
    AS ERROR R-K44-JP5
    FOR BT-514-Organization-Company
    IN *
  ASSERT ((OPT-200-Organization-Company in OPT-300-Contract-Signatory) or (OPT-200-Organization-Company in OPT-300-Procedure-Buyer) or (OPT-200-Organization-Company in OPT-300-Procedure-SProvider) or (OPT-200-Organization-Company in OPT-300-Tenderer) or (OPT-200-Organization-Company in OPT-301-Lot-AddInfo) or (OPT-200-Organization-Company in OPT-301-Lot-DocProvider) or (OPT-200-Organization-Company in OPT-301-Lot-EmployLegis) or (OPT-200-Organization-Company in OPT-301-Lot-EnvironLegis) or (OPT-200-Organization-Company in OPT-301-Lot-FiscalLegis) or (OPT-200-Organization-Company in OPT-301-Lot-Mediator) or (OPT-200-Organization-Company in OPT-301-Lot-ReviewInfo) or (OPT-200-Organization-Company in OPT-301-Lot-ReviewOrg) or (OPT-200-Organization-Company in OPT-301-Lot-TenderEval) or (OPT-200-Organization-Company in OPT-301-Lot-TenderReceipt) or (OPT-200-Organization-Company in OPT-301-LotResult-Financing) or (OPT-200-Organization-Company in OPT-301-LotResult-Paying) or (OPT-200-Organization-Company in OPT-301-Part-AddInfo) or (OPT-200-Organization-Company in OPT-301-Part-DocProvider) or (OPT-200-Organization-Company in OPT-301-Part-EmployLegis) or (OPT-200-Organization-Company in OPT-301-Part-EnvironLegis) or (OPT-200-Organization-Company in OPT-301-Part-FiscalLegis) or (OPT-200-Organization-Company in OPT-301-Part-Mediator) or (OPT-200-Organization-Company in OPT-301-Part-ReviewInfo) or (OPT-200-Organization-Company in OPT-301-Part-ReviewOrg) or (OPT-200-Organization-Company in OPT-301-Part-TenderEval) or (OPT-200-Organization-Company in OPT-301-Part-TenderReceipt) or (OPT-200-Organization-Company in BT-807-Review) or (OPT-200-Organization-Company in BT-808-Review) or (OPT-200-Organization-Company in OPT-301-Tenderer-MainCont) or (OPT-200-Organization-Company in OPT-301-Tenderer-SubCont))
    AS ERROR R-REA-SY4
    FOR OPT-200-Organization-Company
    IN *
  WHEN OPT-200-Organization-Company in OPT-301-Tenderer-SubCont
  ASSERT not(OPT-201-Organization-TouchPoint is present)
    AS ERROR R-9B2-DZ5
    FOR OPT-200-Organization-Company
    IN *
  WHEN OPT-200-Organization-Company in OPT-300-Tenderer
  ASSERT not(OPT-201-Organization-TouchPoint is present)
    AS ERROR R-IDO-DNT
    FOR OPT-200-Organization-Company
    IN *

WITH ND-ContractModification
  ASSERT BT-1501(c)-Contract is unique in /BT-1501(c)-Contract
    AS ERROR R-5OM-DHV
    FOR BT-1501(c)-Contract
    IN *

WITH ND-ContractingParty
  WHEN (OPP-070-notice in ['3','6','9','CEI','14','18','19','22','27','28','31','32','35','40']) and (BT-11-Procedure-Buyer in ['pub-undert', 'pub-undert-cga', 'pub-undert-ra', 'pub-undert-la', 'spec-rights-entity']) and not(BT-02-notice == 'can-modif') and (BT-740-Procedure-Buyer is present)
  ASSERT BT-740-Procedure-Buyer == 'cont-ent'
    AS ERROR R-FGN-0QH
    FOR BT-740-Procedure-Buyer
    IN *
  WHEN (OPP-070-notice in ['3','6','9','CEI','14','18','19','22','27','28','31','32','35','40']) and (BT-11-Procedure-Buyer in ['org-sub', 'org-sub-cga', 'org-sub-ra', 'org-sub-la', 'eu-ins-bod-ag', 'def-cont', 'int-org']) and not(BT-02-notice == 'can-modif') and (BT-740-Procedure-Buyer is present)
  ASSERT BT-740-Procedure-Buyer == 'not-cont-ent'
    AS ERROR R-V8C-1Q1
    FOR BT-740-Procedure-Buyer
    IN *

WITH ND-GroupComposition
  ASSERT count(BT-1375-Procedure) > 1
    AS ERROR R-FIF-B6Y
    FOR BT-1375-Procedure
    IN *
  WHEN BT-1375-Procedure is present
  ASSERT every text:$lot in BT-1375-Procedure satisfies ($lot in /BT-137-Lot)
    AS ERROR R-JLQ-DDV
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, date:$interestA in BT-130-Lot[BT-137-Lot == $lotA], date:$interestB in BT-130-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-ILQ-IW1
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, date:$interestA in BT-131(d)-Lot[BT-137-Lot == $lotA], date:$interestB in BT-131(d)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-T32-WXB
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, date:$interestA in BT-1311(d)-Lot[BT-137-Lot == $lotA], date:$interestB in BT-1311(d)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-PHG-NN3
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, date:$interestA in BT-132(d)-Lot[BT-137-Lot == $lotA], date:$interestB in BT-132(d)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-Z9D-HA1
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, date:$interestA in BT-630(d)-Lot[BT-137-Lot == $lotA], date:$interestB in BT-630(d)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-AKI-UAX
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, date:$interestA in BT-631-Lot[BT-137-Lot == $lotA], date:$interestB in BT-631-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-FHD-XEC
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, time:$interestA in BT-131(t)-Lot[BT-137-Lot == $lotA], time:$interestB in BT-131(t)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-OI4-G01
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, time:$interestA in BT-1311(t)-Lot[BT-137-Lot == $lotA], time:$interestB in BT-1311(t)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-SB3-DK5
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, time:$interestA in BT-132(t)-Lot[BT-137-Lot == $lotA], time:$interestB in BT-132(t)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-USI-2FZ
    FOR BT-1375-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$lotA in BT-1375-Procedure, text:$lotB in BT-1375-Procedure, time:$interestA in BT-630(t)-Lot[BT-137-Lot == $lotA], time:$interestB in BT-630(t)-Lot[BT-137-Lot == $lotB] satisfies ($interestA == $interestB)
    AS ERROR R-X1E-MWE
    FOR BT-1375-Procedure
    IN *

WITH ND-InterestExpressionReceptionPeriod
  WHEN (BT-630(d)-Lot is present) and (BT-05(a)-notice is present) and (BT-758-notice is not present)
  ASSERT BT-630(d)-Lot > BT-05(a)-notice
    AS ERROR R-F4B-0CT
    FOR BT-630(d)-Lot
    IN *

WITH ND-Lot
  WHEN (OPP-070-notice in ['25','26','27','28','29','30','31','32','E4','T02','33','34','35','36','37','38','39','40','E5']) and BT-13713-LotResult is present
  ASSERT (BT-137-Lot in BT-13713-LotResult)
    AS ERROR R-8X7-QPX
    FOR BT-137-Lot
    IN *
  WHEN OPP-070-notice in ['7','8','9','10','11','15','16','17','18','19','22']
  ASSERT (BT-36-Lot is present) or (BT-536-Lot is present and BT-537-Lot is present) or (BT-538-Lot is present)
    AS ERROR R-KSW-MD7
    FOR BT-137-Lot
    IN *

WITH ND-LotAwardCriteria
  ASSERT (every text:$x in BT-5421-Lot satisfies $x == 'ord-imp') or not(some text:$x in BT-5421-Lot satisfies $x == 'ord-imp')
    AS ERROR R-LPT-TIY
    FOR BT-539-Lot
    IN *
  WHEN BT-541-Lot-WeightNumber[BT-5421-Lot == 'ord-imp'] is present
  ASSERT every number:$ordImp in BT-541-Lot-WeightNumber[BT-5421-Lot == 'ord-imp'] satisfies ($ordImp % 1 == 0)
    AS ERROR R-PJX-WS0
    FOR BT-539-Lot
    IN *
  WHEN BT-541-Lot-WeightNumber[BT-5421-Lot == 'ord-imp'] is present
  ASSERT every number:$ordImp in BT-541-Lot-WeightNumber[BT-5421-Lot == 'ord-imp'] satisfies($ordImp <= count(BT-541-Lot-WeightNumber[BT-5421-Lot == 'ord-imp']))
    AS ERROR R-I6L-PY5
    FOR BT-539-Lot
    IN *
  ASSERT ((((1.00 >= sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'dec-exa']))) and ((1.00 - sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'dec-exa'])) <= (0.01 * count(BT-541-Lot-WeightNumber[BT-5421-Lot == 'dec-exa'])))) or (((1.00 <= sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'dec-exa']))) and ((sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'dec-exa']) - 1.00) <= (0.01 * count(BT-541-Lot-WeightNumber[BT-5421-Lot == 'dec-exa']))))) or not(BT-541-Lot-WeightNumber[BT-5421-Lot == 'dec-exa'] is present)
    AS ERROR R-4AW-LCH
    FOR BT-543-Lot
    IN *
  ASSERT ((((100 >= sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'per-exa']))) and ((100 - sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'per-exa'])) <= (1.00 * count(BT-541-Lot-WeightNumber[BT-5421-Lot == 'per-exa'])))) or (((100 <= sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'per-exa']))) and ((sum(BT-541-Lot-WeightNumber[BT-5421-Lot == 'per-exa']) - 100) <= (1.00 * count(BT-541-Lot-WeightNumber[BT-5421-Lot == 'per-exa']))))) or not(BT-541-Lot-WeightNumber[BT-5421-Lot == 'per-exa'] is present)
    AS ERROR R-S1W-NMO
    FOR BT-543-Lot
    IN *

WITH ND-LotAwardCriterion
  ASSERT (count(BT-5423-Lot[BT-5423-Lot =='min-score']) <= 1) and (count(BT-5423-Lot[BT-5423-Lot =='max-pass']) <= 1)
    AS ERROR R-Q9X-DL0
    FOR BT-540-Lot
    IN *

WITH ND-LotAwardWeightCriterionParameter
  WHEN (BT-03-notice in ['result', 'cont-modif', 'dir-awa-pre']) and (BT-5421-Lot is present)
  ASSERT BT-5421-Lot in ['dec-exa', 'ord-imp', 'per-exa', 'poi-exa']
    AS ERROR R-ZLP-UN0
    FOR BT-5421-Lot
    IN *

WITH ND-LotDistribution
  WHEN BT-31-Procedure is present
  ASSERT BT-31-Procedure <= count(BT-137-Lot)
    AS ERROR R-7O4-4VQ
    FOR BT-31-Procedure
    IN *
  WHEN (BT-33-Procedure is present) and (BT-31-Procedure is present)
  ASSERT BT-33-Procedure <= BT-31-Procedure
    AS ERROR R-ATK-LE9
    FOR BT-33-Procedure
    IN *
  WHEN BT-330-Procedure is present
  ASSERT every text:$group in BT-330-Procedure satisfies ($group in /BT-137-LotsGroup)
    AS ERROR R-BU4-2QL
    FOR BT-330-Procedure
    IN *

WITH ND-LotDuration
  WHEN (some text:$x in BT-71-Lot satisfies $x == 'res-pub-ser') and (BT-36-Lot is present)
  ASSERT (BT-36-Lot > P0D) and (BT-36-Lot <= P3Y)
    AS ERROR R-EI0-LGR
    FOR BT-36-Lot
    IN *
  ASSERT ((BT-536-Lot is present) and (BT-537-Lot is present) and (BT-536-Lot < BT-537-Lot)) or not((BT-536-Lot is present) and (BT-537-Lot is present))
    AS ERROR R-MA5-ARM
    FOR BT-536-Lot
    IN *
  WHEN (some text:$x in BT-71-Lot satisfies $x == 'res-pub-ser') and (BT-536-Lot is present) and (BT-537-Lot is present)
  ASSERT ((BT-537-Lot - BT-536-Lot) > P0D) and ((BT-537-Lot - BT-536-Lot) <= P3Y)
    AS ERROR R-CGH-LX2
    FOR BT-536-Lot
    IN *
  ASSERT not(BT-538-Lot == 'UNKNOWN') or (not(BT-03-notice in ['cont-modif','dir-awa-pre'] ) and not(BT-137-Lot in BT-13713-LotResult[BT-142-LotResult == 'selec-w']))
    AS ERROR R-QA4-2UW
    FOR BT-538-Lot
    IN *

WITH ND-LotEmploymentLegislation
  WHEN OPT-301-Lot-EmployLegis is present
  ASSERT ((OPT-301-Lot-EmployLegis in /OPT-200-Organization-Company) or (OPT-301-Lot-EmployLegis in /OPT-201-Organization-TouchPoint))
    AS ERROR R-3YP-47W
    FOR OPT-301-Lot-EmployLegis
    IN *

WITH ND-LotEnvironmentalLegislation
  WHEN OPT-301-Lot-EnvironLegis is present
  ASSERT ((OPT-301-Lot-EnvironLegis in /OPT-200-Organization-Company) or (OPT-301-Lot-EnvironLegis in /OPT-201-Organization-TouchPoint))
    AS ERROR R-7F0-FGU
    FOR OPT-301-Lot-EnvironLegis
    IN *

WITH ND-LotFiscalLegislation
  WHEN OPT-301-Lot-FiscalLegis is present
  ASSERT ((OPT-301-Lot-FiscalLegis in /OPT-200-Organization-Company) or (OPT-301-Lot-FiscalLegis in /OPT-201-Organization-TouchPoint))
    AS ERROR R-X8Y-4DM
    FOR OPT-301-Lot-FiscalLegis
    IN *

WITH ND-LotProcurementScope
  WHEN (OPP-070-notice in ['14','19','28','32','35','40']) and (BT-23-Lot is present)
  ASSERT BT-23-Lot != 'supplies'
    AS ERROR R-P50-M3L
    FOR BT-23-Lot
    IN *
  WHEN (BT-23-Lot is present) and (BT-531-Lot is present)
  ASSERT not(BT-23-Lot in BT-531-Lot)
    AS ERROR R-ZJF-TRP
    FOR BT-23-Lot
    IN *
  WHEN (some text:$x in BT-71-Lot satisfies $x == 'res-pub-ser') and (BT-262-Lot is present)
  ASSERT BT-262-Lot in ['75121000', '75122000', '75123000', '79622000', '79624000', '79625000', '80110000', '80300000', '80420000', '80430000', '80511000', '80520000', '80590000', '85000000', '85100000', '85110000', '85111000', '85111100', '85111200', '85111300', '85111310', '85111320', '85111400', '85111500', '85111600', '85111700', '85111800', '85111810', '85111820', '85111900', '85112000', '85112100', '85112200', '85120000', '85121000', '85121100', '85121200', '85121210', '85121220', '85121230', '85121231', '85121232', '85121240', '85121250', '85121251', '85121252', '85121270', '85121271', '85121280', '85121281', '85121282', '85121283', '85121290', '85121291', '85121292', '85121300', '85130000', '85131000', '85131100', '85131110', '85140000', '85141000', '85141100', '85141200', '85141210', '85141211', '85141220', '85142000', '85142100', '85142200', '85142300', '85142400', '85143000', '85144000', '85144100', '85145000', '85146000', '85146100', '85146200', '85147000', '85148000', '85149000', '85150000', '85160000', '85170000', '85171000', '85172000', '85200000', '85210000', '85300000', '85310000', '85311000', '85311100', '85311200', '85311300', '85312000', '85312100', '85312110', '85312120', '85312200', '85312300', '85312310', '85312320', '85312330', '85312400', '85312500', '85312510', '85320000', '85321000', '85322000', '85323000',  '92500000', '92600000', '98133000', '98133110']
    AS ERROR R-W0T-ORH
    FOR BT-262-Lot
    IN *
  WHEN (BT-23-Lot == 'supplies') and (BT-262-Lot is present)
  ASSERT starts-with(BT-262-Lot,'0') or starts-with(BT-262-Lot,'1') or starts-with(BT-262-Lot,'2') or starts-with(BT-262-Lot,'3') or starts-with(BT-262-Lot,'40') or starts-with(BT-262-Lot,'41') or starts-with(BT-262-Lot,'42') or starts-with(BT-262-Lot,'43') or starts-with(BT-262-Lot,'44') or starts-with(BT-262-Lot,'48')
    AS ERROR R-75D-MTG
    FOR BT-262-Lot
    IN *
  WHEN (BT-23-Lot == 'works') and (BT-262-Lot is present)
  ASSERT starts-with(BT-262-Lot,'45')
    AS ERROR R-VC1-7IU
    FOR BT-262-Lot
    IN *
  WHEN (BT-23-Lot == 'services') and (BT-262-Lot is present)
  ASSERT starts-with(BT-262-Lot,'49') or starts-with(BT-262-Lot,'5') or starts-with(BT-262-Lot,'6') or starts-with(BT-262-Lot,'7') or starts-with(BT-262-Lot,'8') or starts-with(BT-262-Lot,'9')
    AS ERROR R-9PG-OI2
    FOR BT-262-Lot
    IN *
  WHEN BT-02-notice in ['can-desg','can-social','can-standard','can-tran','cn-desg','cn-social','cn-standard','compl','corr','pin-cfc-social','pin-cfc-standard','pin-rtl','pin-tran','pmc','qu-sy','subco','veat']
  ASSERT (BT-5141-Lot is present) or (BT-727-Lot is present)
    AS ERROR R-P9H-TM5
    FOR BT-727-Lot
    IN *

WITH ND-LotResult
  WHEN (BT-760-LotResult is present) and (OPP-070-notice in ['29','30','31','32','33','34','35','36','37','E4','E5'])
  ASSERT ((count(BT-759-LotResult[BT-760-LotResult == 't-small']) == 1) and (count(BT-759-LotResult[BT-760-LotResult == 't-micro']) == 1) and (count(BT-759-LotResult[BT-760-LotResult == 't-med']) == 1) and (count(BT-759-LotResult[BT-760-LotResult == 't-sme']) == 0)) or ((count(BT-759-LotResult[BT-760-LotResult == 't-small']) == 0) and (count(BT-759-LotResult[BT-760-LotResult == 't-micro']) == 0) and (count(BT-759-LotResult[BT-760-LotResult == 't-med']) == 0) and (count(BT-759-LotResult[BT-760-LotResult == 't-sme']) == 1))
    AS ERROR R-VXR-RRM
    FOR BT-13713-LotResult
    IN *
  WHEN (BT-760-LotResult is present) and (OPP-070-notice in ['29','30','31','32','33','34','35','36','37','E4','E5'])
  ASSERT (count(BT-759-LotResult[BT-760-LotResult == 't-large']) == 1)
    AS ERROR R-KUR-MV6
    FOR BT-13713-LotResult
    IN *
  WHEN (BT-760-LotResult is present) and (OPP-070-notice in ['29','30','31','32','33','34','35','36','37','E4','E5'])
  ASSERT (count(BT-759-LotResult[BT-760-LotResult == 't-no-eea']) == 1)
    AS ERROR R-W4X-DYE
    FOR BT-13713-LotResult
    IN *
  WHEN (BT-760-LotResult is present) and (OPP-070-notice in ['29','30','31','32','33','34','35','36','37','E4','E5'])
  ASSERT (count(BT-759-LotResult[BT-760-LotResult == 't-oth-eea']) == 1)
    AS ERROR R-9MG-WIJ
    FOR BT-13713-LotResult
    IN *
  ASSERT (every number:$x in BT-759-LotResult[BT-760-LotResult == 't-esubm'], number:$t in BT-759-LotResult[BT-760-LotResult == 'tenders'] satisfies $x <= $t) or not(BT-759-LotResult[BT-760-LotResult == 't-esubm'] is present) or not(BT-759-LotResult[BT-760-LotResult == 'tenders'] is present)
    AS ERROR R-1AX-FF0
    FOR BT-13713-LotResult
    IN *
  ASSERT (every number:$x in BT-759-LotResult[BT-760-LotResult == 't-sme'], number:$t in BT-759-LotResult[BT-760-LotResult == 'tenders'] satisfies $x <= $t) or not(BT-759-LotResult[BT-760-LotResult == 't-sme'] is present) or not(BT-759-LotResult[BT-760-LotResult == 'tenders'] is present)
    AS ERROR R-TWR-L6X
    FOR BT-13713-LotResult
    IN *
  ASSERT (every number:$x in BT-759-LotResult[BT-760-LotResult == 't-verif-inad'], number:$t in BT-759-LotResult[BT-760-LotResult == 'tenders'] satisfies $x <= $t) or not(BT-759-LotResult[BT-760-LotResult == 't-verif-inad'] is present) or not(BT-759-LotResult[BT-760-LotResult == 'tenders'] is present)
    AS ERROR R-7KQ-UNL
    FOR BT-13713-LotResult
    IN *
  ASSERT (every number:$x in BT-759-LotResult[BT-760-LotResult == 't-verif-inad-low'], number:$t in BT-759-LotResult[BT-760-LotResult == 't-verif-inad'] satisfies $x <= $t) or not(BT-759-LotResult[BT-760-LotResult == 't-verif-inad-low'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-verif-inad'] is present)
    AS ERROR R-26T-6F0
    FOR BT-13713-LotResult
    IN *
  ASSERT BT-13713-LotResult in /BT-137-Lot
    AS ERROR R-I7G-1DZ
    FOR BT-13713-LotResult
    IN *
  WHEN BT-105-Procedure not in ['restricted','neg-w-call','comp-dial','innovation','oth-mult']
  ASSERT count(BT-759-LotResult[BT-760-LotResult == 'part-req']) == 0
    AS ERROR R-936-YL4
    FOR BT-13713-LotResult
    IN *
  WHEN (BT-760-LotResult is present) and (OPP-070-notice in ['29','30','32','36','37'])
  ASSERT count(BT-759-LotResult[BT-760-LotResult == 't-esubm']) == 1
    AS ERROR R-SVB-MJ0
    FOR BT-13713-LotResult
    IN *
  WHEN (BT-760-LotResult is present) and (OPP-070-notice in ['29','30','31','32','33','34','35','36','37','E4','E5'])
  ASSERT count(BT-759-LotResult[BT-760-LotResult == 'tenders']) == 1
    AS ERROR R-6IN-5N7
    FOR BT-13713-LotResult
    IN *
  ASSERT sum(BT-759-LotResult[BT-760-LotResult == 'tenders']) == (sum(BT-759-LotResult[BT-760-LotResult == 't-large']) + sum(BT-759-LotResult[BT-760-LotResult == 't-med']) + sum(BT-759-LotResult[BT-760-LotResult == 't-small']) + sum(BT-759-LotResult[BT-760-LotResult == 't-micro'])) or not(BT-759-LotResult[BT-760-LotResult == 'tenders'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-large'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-med'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-small'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-micro'] is present)
    AS ERROR R-QFU-FN0
    FOR BT-13713-LotResult
    IN *
  ASSERT sum(BT-759-LotResult[BT-760-LotResult == 'tenders']) == (sum(BT-759-LotResult[BT-760-LotResult == 't-large']) + sum(BT-759-LotResult[BT-760-LotResult == 't-sme'])) or not(BT-759-LotResult[BT-760-LotResult == 'tenders'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-large'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-sme'] is present)
    AS ERROR R-3EF-GU4
    FOR BT-13713-LotResult
    IN *
  ASSERT sum(BT-759-LotResult[BT-760-LotResult == 'tenders']) >= (sum(BT-759-LotResult[BT-760-LotResult == 't-no-eea']) + sum(BT-759-LotResult[BT-760-LotResult == 't-oth-eea'])) or not(BT-759-LotResult[BT-760-LotResult == 'tenders'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-no-eea'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-oth-eea'] is present)
    AS ERROR R-NWB-0YY
    FOR BT-13713-LotResult
    IN *
  ASSERT sum(BT-759-LotResult[BT-760-LotResult == 'tenders']) >= (sum(BT-759-LotResult[BT-760-LotResult == 't-verif-inad']) + sum(BT-759-LotResult[BT-760-LotResult == 't-no-verif'])) or not(BT-759-LotResult[BT-760-LotResult == 'tenders'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-verif-inad'] is present) or not(BT-759-LotResult[BT-760-LotResult == 't-no-verif'] is present)
    AS ERROR R-JS4-MVI
    FOR BT-13713-LotResult
    IN *
  WHEN (BT-142-LotResult == 'selec-w') and (count(BT-759-LotResult[BT-760-LotResult == 'tenders']) == 1)
  ASSERT sum(BT-759-LotResult[BT-760-LotResult == 'tenders']) >= 1
    AS ERROR R-O7T-C62
    FOR BT-13713-LotResult
    IN *
  WHEN (BT-13713-LotResult in BT-137-Lot[BT-765-Lot in ['fa-mix','fa-w-rc','fa-wo-rc']]) and (BT-142-LotResult == 'selec-w') and (every text:$x in OPT-315-LotResult satisfies $x not in OPT-316-Contract[(BT-768-Contract == TRUE)])
  ASSERT (BT-709-LotResult is present) or (BT-660-LotResult is present)
    AS ERROR R-DTZ-E0V
    FOR BT-142-LotResult
    IN *
  WHEN OPP-070-notice == 'T02'
  ASSERT BT-142-LotResult == 'selec-w'
    AS ERROR R-OVA-H2C
    FOR BT-142-LotResult
    IN *
  WHEN (BT-710-LotResult is present) and (BT-711-LotResult is present)
  ASSERT BT-710-LotResult <= BT-711-LotResult
    AS ERROR R-S2C-D0M
    FOR BT-710-LotResult
    IN *
  WHEN (BT-710-LotResult is present) and (BT-711-LotResult is present)
  ASSERT BT-710-LotResult/@currencyID == BT-711-LotResult/@currencyID
    AS ERROR R-7DT-YS4
    FOR BT-710-LotResult
    IN *

WITH ND-LotReviewTerms
  WHEN OPT-301-Lot-Mediator is present
  ASSERT (OPT-301-Lot-Mediator in /OPT-200-Organization-Company) or (OPT-301-Lot-Mediator in /OPT-201-Organization-TouchPoint)
