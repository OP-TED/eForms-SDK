    FOR BT-5141-Part
    IN 4,5,6,E2
  WHEN not(BT-727-Part in ['anyw', 'anyw-eea'])
  ASSERT BT-5141-Part is present
    AS ERROR R-AR0-ASS
    FOR BT-5141-Part
    IN 4,5,6,E2
  WHEN BT-5071-Part is present
  ASSERT BT-727-Part is not present
    AS ERROR R-E0C-E1H
    FOR BT-727-Part
    IN 4,5,6,E2
  WHEN BT-727-Part is not present and BT-5141-Part is not present
  ASSERT BT-728-Part is not present
    AS ERROR R-DWX-3GA
    FOR BT-728-Part
    IN 4,5,6,E2
  WHEN (BT-727-Part is not present) and (BT-5071-Part is not present) and (BT-5131-Part is not present)
  ASSERT BT-728-Part is present
    AS ERROR R-QA8-MRU
    FOR BT-728-Part
    IN 4,5,6,E2

