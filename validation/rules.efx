  WHEN BT-5101(b)-Part is not present
  ASSERT BT-5101(c)-Part is not present
    AS ERROR R-XA2-E21
    FOR BT-5101(c)-Part
    IN 4,5,6,E2
  WHEN BT-5131-Part is not present
  ASSERT BT-5121-Part is not present
    AS ERROR R-I62-NWQ
    FOR BT-5121-Part
    IN 4,5,6,E2
  WHEN BT-5141-Part in #postcode-country and BT-5101(a)-Part is present
  ASSERT BT-5121-Part is present
    AS ERROR R-2VO-7QQ
    FOR BT-5121-Part
    IN 4,5,6,E2
  WHEN BT-727-Part is present or BT-5141-Part is not present
  ASSERT BT-5131-Part is not present
    AS ERROR R-H80-CVX
    FOR BT-5131-Part
    IN 4,5,6,E2
  WHEN BT-727-Part in ['anyw', 'anyw-eea']
  ASSERT BT-5141-Part is not present
