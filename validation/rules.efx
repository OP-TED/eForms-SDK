  ASSERT every text:$resultTender in OPT-320-LotResult, text:$resultLot in BT-13713-LotResult, text:$tenderLot in BT-13714-Tender[OPT-321-Tender == $resultTender] satisfies (($resultLot == $tenderLot) or ($resultLot in BT-1375-Procedure[BT-330-Procedure == $tenderLot]))
    AS ERROR R-QGS-DVQ
    FOR OPT-320-LotResult
    IN *

#include "stage-5m.efx"

