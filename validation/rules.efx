  ASSERT BT-1118-NoticeResult is not present
    AS ERROR R-5LM-KZL
    FOR BT-1118-NoticeResult
    IN 38,39,E6
  WHEN not(some text:$x in BT-142-LotResult[BT-13713-LotResult in BT-137-Lot[BT-765-Lot in ['fa-mix','fa-w-rc','fa-wo-rc']]] satisfies $x == 'selec-w') or (BT-660-LotResult is not present)
  ASSERT BT-1118-NoticeResult is not present
    AS ERROR R-7UX-V14
    FOR BT-1118-NoticeResult
    IN 29,30,31,33,34,E4,E5
  WHEN (every text:$x in BT-13713-LotResult satisfies $x in BT-137-Lot[BT-765-Lot not in ['fa-mix','fa-w-rc','fa-wo-rc']]) or (BT-660-LotResult is not present)
