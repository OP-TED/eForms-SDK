    FOR BT-106-Procedure
    IN 17,30,E3,E4,E5
  WHEN not(BT-105-Procedure not in ['open','restricted','neg-w-call'])
  ASSERT BT-106-Procedure is present
    AS ERROR R-D8A-77K
    FOR BT-106-Procedure
    IN 16
  WHEN not(BT-105-Procedure not in ['neg-w-call','restricted'])
  ASSERT BT-106-Procedure is present
    AS ERROR R-EE2-NNB
    FOR BT-106-Procedure
    IN 18
  WHEN not(BT-105-Procedure not in ['open','restricted','neg-w-call','comp-dial','innovation'])
  ASSERT BT-106-Procedure is present
    AS ERROR R-P7S-91M
    FOR BT-106-Procedure
    IN 17
  WHEN not(BT-105-Procedure == 'neg-wo-call')
  ASSERT BT-136-Procedure is not present
    AS ERROR R-LW4-36W
    FOR BT-136-Procedure
    IN 25,26,27,28,29,30,31,33,34,E4,E5
  WHEN count(/BT-137-Lot) < 2
