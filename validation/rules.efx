WITH ND-LotTenderingProcess
  WHEN OPP-070-notice in ['14','19','28','32','35','40'] and (BT-115-Lot is present) and (BT-23-Lot == 'services')
  ASSERT BT-115-Lot == FALSE
    AS ERROR R-NME-ANR
    FOR BT-115-Lot
    IN *
  ASSERT (BT-631-Lot < BT-130-Lot) or not(BT-631-Lot is present) or not(BT-130-Lot is present)
    AS ERROR R-BGD-GP8
    FOR BT-130-Lot
    IN *
  WHEN (BT-131(d)-Lot is present) and (BT-13(d)-Lot is present)
  ASSERT BT-13(d)-Lot <= BT-131(d)-Lot
    AS ERROR R-3PP-8LS
    FOR BT-131(d)-Lot
    IN *
  WHEN (BT-131(d)-Lot is present) and (BT-05(a)-notice is present) and not(BT-758-notice is present)
  ASSERT BT-131(d)-Lot > BT-05(a)-notice
    AS ERROR R-NB2-086
    FOR BT-131(d)-Lot
    IN *
  WHEN (BT-131(d)-Lot is present) and (BT-738-notice is present) and not(BT-758-notice is present)
  ASSERT BT-131(d)-Lot > BT-738-notice
    AS ERROR R-P20-V3I
    FOR BT-131(d)-Lot
    IN *
  WHEN (BT-1311(d)-Lot is present) and (BT-130-Lot is present)
  ASSERT (BT-1311(d)-Lot < BT-130-Lot)
    AS ERROR R-B32-UKX
    FOR BT-1311(d)-Lot
    IN *
  WHEN (BT-1311(d)-Lot is present) and (BT-13(d)-Lot is present)
  ASSERT BT-13(d)-Lot <= BT-1311(d)-Lot
    AS ERROR R-O12-BOI
    FOR BT-1311(d)-Lot
    IN *
  WHEN (BT-1311(d)-Lot is present) and (BT-05(a)-notice is present) and not(BT-758-notice is present)
  ASSERT BT-1311(d)-Lot > BT-05(a)-notice
    AS ERROR R-35W-SR7
    FOR BT-1311(d)-Lot
    IN *
  WHEN (BT-1311(d)-Lot is present) and (BT-738-notice is present) and not(BT-758-notice is present)
  ASSERT BT-1311(d)-Lot > BT-738-notice
    AS ERROR R-8PU-S4J
    FOR BT-1311(d)-Lot
    IN *
  WHEN (BT-630(d)-Lot is present) and (BT-738-notice is present) and not(BT-758-notice is present)
  ASSERT BT-630(d)-Lot > BT-738-notice
    AS ERROR R-QWR-GG3
    FOR BT-630(d)-Lot
    IN *
  ASSERT (BT-631-Lot > BT-630(d)-Lot) or not(BT-631-Lot is present) or not(BT-630(d)-Lot is present)
    AS ERROR R-AK9-SFI
    FOR BT-631-Lot
    IN *

