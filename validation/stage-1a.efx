--- STAGE 1a ---

WITH ND-Root
  ASSERT OPP-070-notice is present
    AS ERROR R-TMP-001
    FOR OPP-070-notice
    IN *
  ASSERT ND-Lot is not present
    AS ERROR R-TMP-002
    FOR ND-Lot
    IN 1-6,E2,X01,X02
  ASSERT ND-Lot is present
    AS ERROR R-TMP-003
    FOR ND-Lot
    IN 7-40,E3-E6,T01,T02
  ASSERT ND-Part is not present
    AS ERROR R-TMP-004
    FOR ND-Part
    IN 7-40,E3-E6,T01,T02,X01,X02
  ASSERT ND-Part is present
    AS ERROR R-TMP-005
    FOR ND-Part
    IN 4-6,E2
;
