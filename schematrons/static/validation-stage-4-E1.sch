        <assert id="R-YCR-P6H" role="ERROR" diagnostics="ND-LotTenderingTerms_BT-18-Lot" test="(cac:TenderRecipientParty/cbc:EndpointID) or (not(not(../cac:TenderingProcess/cbc:SubmissionMethodCode[@listName='esubmission']/normalize-space(text()) = 'not-allowed')))">rule|text|R-YCR-P6H</assert>
