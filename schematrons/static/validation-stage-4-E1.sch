        <assert id="R-VFN-9LJ" role="ERROR" diagnostics="ND-LotTenderingProcess_BT-19-Lot" test="(not(cac:ProcessJustification/cbc:ProcessReasonCode[@listName='no-esubmission-justification'])) or (not(not(cbc:SubmissionMethodCode[@listName='esubmission']/normalize-space(text()) = 'not-allowed')))">rule|text|R-VFN-9LJ</assert>
        <assert id="R-A9C-L0K" role="ERROR" diagnostics="ND-LotTenderingProcess_BT-745-Lot" test="(not(cac:ProcessJustification/cbc:Description)) or (not(cbc:SubmissionMethodCode[@listName='esubmission']/normalize-space(text()) = 'required'))">rule|text|R-A9C-L0K</assert>
