        <assert id="R-PCS-CCL" role="ERROR" diagnostics="ND-PartMainClassification_BT-26_m_-Part" test="(cbc:ItemClassificationCode/@listName) or (not(not(not(cbc:ItemClassificationCode))))">rule|text|R-PCS-CCL</assert>
