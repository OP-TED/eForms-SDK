// View E5
// File generated from metadata database
let text:$myglobalvar=BT-701-notice;let $lot-by-lot-or-gol-id index BT-137-Lot by BT-137-Lot;let $lot-name-by-lot-or-gol-id index BT-21-Lot by BT-137-Lot;let indicator:?myfunc3()=TRUE; let indicator:?exists-common-value(text*:$seq1, text*:$seq2) = (count(value-intersect($seq1, $seq2)) > 0); let template:role-and-name(text:$label-id, text:$org-tpo-id) display #{${$label-id}}: ${BT-500-Organization-Company[OPT-200-Organization-Company == $org-tpo-id or $org-tpo-id in OPT-201-Organization-TouchPoint]}${BT-500-Organization-TouchPoint[OPT-201-Organization-TouchPoint == $org-tpo-id]};let template:mytemplate(text:$id) display ${BT-500-Organization-Company[OPT-200-Organization-Company == $id]}; // GLOBALS // let $lot-name-by-gol-id index BT-21-Lot by ( for text:$this-lot-id in BT-137-Lot return BT-330-Procedure[ $this-lot-id in BT-1375-Procedure]);// let template:mytemplate(text:$id) display ${BT-500-Organization-Company[OPT-200-Organization-Company == $id]};// let template:mytemplate(text:$id) display ${efx:preferred-language-text(BT-500-Organization-Company[OPT-200-Organization-Company == $id])};// let context:$all-organisations = OPT-200-Organization-Company;// let text:?org-tpo-name(text:$id) = if ($id in OPT-201-Organization-TouchPoint) then concat(BT-500-Organization-Company[$id in OPT-201-Organization-TouchPoint], ' - ', BT-500-Organization-TouchPoint[$id in OPT-201-Organization-TouchPoint]) else BT-500-Organization-Company[$id in OPT-200-Organization-Company];// WITH BT-137-Lot[OPT-301-Lot-AddInfo is present], text:$refid = OPT-301-Lot-AddInfo, text*:$org_name = distinct-values(BT-500-Organization-Company[(OPT-200-Organization-Company == $refid) or ($refid in OPT-201-Organization-TouchPoint)]), text*:$tpo_names = distinct-values(BT-500-Organization-TouchPoint[OPT-201-Organization-TouchPoint == $refid]) DISPLAY #{auxiliary|text|organisation-providing-info-procedure}: ${$org_name}${if (count($tpo_names) > 0) then concat(' - ', $tpo_names[1]) else ''} ; // Organisation providing additional information about the procurement procedure (Lot)
1 WHEN OPT-300-Procedure-Buyer is present DISPLAY #{auxiliary|text|buyer}; // 1 Buyer
	1 WITH ND-ContractingParty DISPLAY #{auxiliary|text|buyer}; // 1.1 Buyer
		WITH ND-ContractingParty DISPLAY #{field|name|BT-500-Organization-Company}: ${for text:$orgid in OPT-300-Procedure-Buyer, text:$orgname in BT-500-Organization-Company[OPT-200-Organization-Company == $orgid] return $orgname}; // Official name
		WITH BT-11-Procedure-Buyer DISPLAY #{name}: #value; // Legal type of the buyer
		WITH BT-740-Procedure-Buyer[BT-740-Procedure-Buyer == 'cont-ent'] DISPLAY #{name}; // Buyer Contracting Entity
		WITH BT-10-Procedure-Buyer DISPLAY #{name}: #value; // Activity of the contracting authority
		WITH BT-610-Procedure-Buyer DISPLAY #{name}: #value; // Activity Entity
2 DISPLAY #{auxiliary|text|procedure}; // 2 Procedure
	1 WITH ND-ProcedureProcurementScope DISPLAY #{auxiliary|text|procedure}; // 2.1 Procedure
		WITH ND-ProcedureProcurementScope DISPLAY #{field|name|BT-21-Procedure}: ${preferred-language-text(BT-21-Procedure)}; // Procedure Title
		WITH ND-ProcedureProcurementScope DISPLAY #{field|name|BT-24-Procedure}: ${preferred-language-text(BT-24-Procedure)}; // Procedure Description
		WITH BT-04-notice DISPLAY #{name}: $value; // Procedure identifier
		WITH BT-22-Procedure DISPLAY #{name}: $value; // Internal identifier
		0 WITH BT-105-Procedure DISPLAY #{name}: ${if (BT-105-Procedure == 'unpublished') then '' else BT-105-Procedure} #{${if (BT-105-Procedure == 'unpublished') then 'auxiliary|text|unpublished' else '' }}; // Type of the procedure
			WITH BT-197(BT-105)-Procedure DISPLAY #{field|name|BT-197(BT-105)-Procedure}: #{BT-197(BT-105)-Procedure}; // Unpublished Justification Code
			WITH BT-105-Procedure[BT-196(BT-105)-Procedure is present] DISPLAY #{field|name|BT-196(BT-105)-Procedure}: ${preferred-language-text(BT-196(BT-105)-Procedure)}; // Unpublished Justification Description
			WITH BT-105-Procedure[BT-198(BT-105)-Procedure is present] DISPLAY #{field|name|BT-198(BT-105)-Procedure}: ${BT-198(BT-105)-Procedure}; // Unpublished Access Date
		0 WITH BT-106-Procedure DISPLAY #{name}: #{${if (BT-106-Procedure == '0') then 'auxiliary|text|unpublished' else concat('code|name|indicator.',BT-106-Procedure)}} ; // The procedure is accelerated (true/false)
			WITH BT-197(BT-106)-Procedure DISPLAY #{field|name|BT-197(BT-106)-Procedure}: #{BT-197(BT-106)-Procedure}; // Unpublished Justification Code
			WITH BT-106-Procedure[BT-196(BT-106)-Procedure is present] DISPLAY #{field|name|BT-196(BT-106)-Procedure}: ${preferred-language-text(BT-196(BT-106)-Procedure)}; // Unpublished Justification Description
			WITH BT-106-Procedure[BT-198(BT-106)-Procedure is present] DISPLAY #{field|name|BT-198(BT-106)-Procedure}: ${BT-198(BT-106)-Procedure}; // Unpublished Access Date
		0 WITH ND-ProcedureTenderingProcess[BT-1351-Procedure is present] DISPLAY #{field|name|BT-1351-Procedure}: ${if (BT-1351-Procedure == 'unpublished') then '' else preferred-language-text(BT-1351-Procedure)} #{${if (BT-1351-Procedure == 'unpublished') then 'auxiliary|text|unpublished' else '' }} ; // Justification for the accelerated procedure
			WITH BT-197(BT-1351)-Procedure DISPLAY #{field|name|BT-197(BT-1351)-Procedure}: #{BT-197(BT-1351)-Procedure}; // Unpublished Justification Code
			WITH ND-ProcedureTenderingProcess[BT-196(BT-1351)-Procedure is present] DISPLAY #{field|name|BT-196(BT-1351)-Procedure}: ${preferred-language-text(BT-196(BT-1351)-Procedure)}; // Unpublished Justification Description
			WITH BT-198(BT-1351)-Procedure DISPLAY #{field|name|BT-198(BT-1351)-Procedure}: ${BT-198(BT-1351)-Procedure}; // Unpublished Access Date
		0 WITH ND-ProcedureTenderingProcess[BT-88-Procedure is present] DISPLAY #{field|name|BT-88-Procedure}: ${if (BT-88-Procedure == 'unpublished') then '' else preferred-language-text(BT-88-Procedure)} #{${if (BT-88-Procedure == 'unpublished') then 'auxiliary|text|unpublished' else '' }} ; // Procedure Features / Description of the procedure
			WITH BT-197(BT-88)-Procedure DISPLAY #{field|name|BT-197(BT-88)-Procedure}: #{BT-197(BT-88)-Procedure}; // Unpublished Justification Code
			WITH ND-ProcedureTenderingProcess[BT-196(BT-88)-Procedure is present] DISPLAY #{field|name|BT-196(BT-88)-Procedure}: ${preferred-language-text(BT-196(BT-88)-Procedure)}; // Unpublished Justification Description
			WITH BT-198(BT-88)-Procedure DISPLAY #{field|name|BT-198(BT-88)-Procedure}: ${BT-198(BT-88)-Procedure}; // Unpublished Access Date
		1 WITH ND-ProcedureProcurementScope[(BT-23-Procedure is present) or (BT-531-Procedure is present) or (BT-262-Procedure is present) or (BT-263-Procedure is present)] DISPLAY #{auxiliary|text|purpose}; // 2.1.1 Purpose
			WITH BT-23-Procedure DISPLAY #{field|name|BT-23-Procedure}: #{BT-23-Procedure}; // Nature of the contract
			WITH ND-ProcedureProcurementScope[BT-531-Procedure is present] DISPLAY #{field|name|BT-531-Procedure}: #{BT-531-Procedure}; // Additional nature of the contract
			WITH BT-262-Procedure[BT-26(m)-Procedure == 'cpv'] DISPLAY #{field|name|BT-262-Procedure}( ${BT-26(m)-Procedure}): ${BT-262-Procedure} #{BT-262-Procedure} ; // Main classification (CPV)
			WITH BT-263-Procedure[BT-26(a)-Procedure == 'cpv'] DISPLAY #{field|name|BT-263-Procedure}( ${BT-26(a)-Procedure}): ${BT-263-Procedure} #{BT-263-Procedure} ; // Additional classification (CPV)
		2 WITH ND-ProcedurePlacePerformance DISPLAY #{auxiliary|text|place-performance}; // 2.1.2 Place of performance
			WITH BT-5101(a)-Procedure DISPLAY #{name}: $value ${BT-5101(b)-Procedure} ${BT-5101(c)-Procedure} ; // Place Performance Postal address
			WITH BT-5131-Procedure DISPLAY #{name}: $value; // Place Performance Town
			WITH BT-5121-Procedure DISPLAY #{name}: $value; // Place Performance Post Code
			WITH BT-5071-Procedure DISPLAY #{name}: #{BT-5071-Procedure} ($value) ; // Place Performance Country Subdivision
			WITH BT-5141-Procedure DISPLAY #{name}: #value; // Place Performance Country
			WITH BT-727-Procedure DISPLAY #{BT-727-Procedure}; // Place Performance Services Other
			WITH ND-ProcedurePlacePerformanceAdditionalInformation[BT-728-Procedure is present] DISPLAY #{field|name|BT-728-Procedure}: ${preferred-language-text(BT-728-Procedure)}; // Place Performance Additional information
		3 WITH ND-ProcedureProcurementScope[(BT-27-Procedure is present) or (BT-271-Procedure is present)] DISPLAY #{auxiliary|text|value}; // 2.1.3 Value
			WITH BT-27-Procedure DISPLAY #{name}: ${format-number(BT-27-Procedure, '###,##0.##')} #{code|name|${concat('currency.', BT-27-Procedure/@currencyID)}} ; // Estimated value
			WITH BT-271-Procedure DISPLAY #{name}: ${format-number(BT-271-Procedure, '###,##0.##')} #{code|name|${concat('currency.', BT-271-Procedure/@currencyID)}} ; // Estimated Framework Maximum Value
		4 WITH ND-ProcedureProcurementScope[BT-01-notice is present] DISPLAY #{auxiliary|text|general-information}; // 2.1.4 General information
			WITH ND-ProcedureProcurementScope[BT-300-Procedure is present] DISPLAY #{field|name|BT-300-Procedure}: ${preferred-language-text(BT-300-Procedure)}; // Additional information
			WITH ND-ProcedureProcurementScope DISPLAY #{auxiliary|text|legal-basis}:; // Legal basis
			WITH BT-01-notice DISPLAY #{BT-01-notice}; // Procedure Legal Basis
			WITH BT-01(c)-Procedure DISPLAY $value - ${preferred-language-text(BT-01(d)-Procedure)}; // Procedure Legal Basis (ID) - Procedure Legal Basis (Description)
			WITH BT-01(e)-Procedure DISPLAY ${preferred-language-text(BT-01(f)-Procedure)}; // Procedure Legal Basis (no ID) Description
4 WITH ND-Root[BT-137-LotsGroup is present] DISPLAY #{auxiliary|text|group-of-lots}; // 4 Group of lots
	1 WITH ND-LotsGroup DISPLAY #{field|name|BT-330-Procedure}: ${BT-137-LotsGroup}; // 4.1 Group of lots
		WITH BT-137-LotsGroup DISPLAY #{field|name|BT-1375-Procedure}: ${for text:$gloid in BT-137-LotsGroup return BT-1375-Procedure[BT-330-Procedure == $gloid]}; // Lots included / Group Lot Identifier 
		WITH BT-137-LotsGroup[BT-21-LotsGroup is present] DISPLAY #{field|name|BT-21-LotsGroup}: ${preferred-language-text(BT-21-LotsGroup)}; // Title of LotsGroup
		WITH BT-137-LotsGroup[BT-24-LotsGroup is present] DISPLAY #{field|name|BT-24-LotsGroup}: ${preferred-language-text(BT-24-LotsGroup)}; // Description of LotsGroup
		WITH BT-22-LotsGroup DISPLAY #{name}: $value; // Internal identifier of LotsGroup
		1 WITH BT-137-LotsGroup[(BT-27-LotsGroup is present) or (BT-271-LotsGroup is present) or (BT-157-LotsGroup is present)] DISPLAY #{auxiliary|text|value}; // 4.1.1 Value
			WITH BT-27-LotsGroup DISPLAY #{name}: ${format-number(BT-27-LotsGroup, '###,##0.##')} #{code|name|${concat('currency.', BT-27-LotsGroup/@currencyID)}} ; // Estimated value
			WITH BT-271-LotsGroup DISPLAY #{name}: ${format-number(BT-271-LotsGroup, '###,##0.##')} #{code|name|${concat('currency.', BT-271-LotsGroup/@currencyID)}} ; // Framework Maximum Value
			WITH BT-157-LotsGroup DISPLAY #{name}: ${format-number(BT-157-LotsGroup, '###,##0.##')} #{code|name|${concat('currency.', BT-157-LotsGroup/@currencyID)}} ; // Maximum value of the framework agreement within the group of lots
		2 WITH ND-LotsGroupProcurementScope[BT-300-LotsGroup is present] DISPLAY #{auxiliary|text|general-information}; // 4.1.2 General information
			WITH BT-137-LotsGroup[BT-300-LotsGroup is present] DISPLAY #{field|name|BT-300-LotsGroup}: ${preferred-language-text(BT-300-LotsGroup)}; // Additional information
		3 WITH ND-LotsGroupAwardCriteria DISPLAY #{auxiliary|text|award-criteria}; // 4.1.3 Award criteria
			0 WITH ND-LotsGroupAwardCriterion DISPLAY #{auxiliary|text|criterion}:; // Criterion
				0 WITH ND-LotsGroupAwardCriterion[BT-539-LotsGroup is present ] DISPLAY #{field|name|BT-539-LotsGroup}: #{${if (BT-539-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else concat('code|name|award-criterion-type.', BT-539-LotsGroup)}} ; // Criterion Type
					WITH BT-197(BT-539)-LotsGroup DISPLAY #{field|name|BT-197(BT-539)-LotsGroup}: #{BT-197(BT-539)-LotsGroup}; // Unpublished Justification Code
					WITH BT-539-LotsGroup[BT-196(BT-539)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-539)-LotsGroup}: ${preferred-language-text(BT-196(BT-539)-LotsGroup)}; // Unpublished Justification Description
					WITH BT-539-LotsGroup[BT-198(BT-539)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-539)-LotsGroup}: ${BT-198(BT-539)-LotsGroup}; // Unpublished Access Date
				0 WITH ND-LotsGroupAwardCriterion[BT-734-LotsGroup is present] DISPLAY #{field|name|BT-734-LotsGroup}: ${if (BT-734-LotsGroup == 'unpublished') then '' else preferred-language-text(BT-734-LotsGroup)} #{${if (BT-734-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else ''}} ; // Criterion Name
					WITH BT-197(BT-734)-LotsGroup DISPLAY #{field|name|BT-197(BT-734)-LotsGroup}: #{BT-197(BT-734)-LotsGroup}; // Unpublished Justification Code
					WITH ND-LotsGroupAwardCriteriaNameUnpublish[BT-196(BT-734)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-734)-LotsGroup}: ${preferred-language-text(BT-196(BT-734)-LotsGroup)}; // Unpublished Justification Description
					WITH ND-LotsGroupAwardCriteriaNameUnpublish[BT-198(BT-734)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-734)-LotsGroup}: ${BT-198(BT-734)-LotsGroup}; // Unpublished Access Date
				0 WITH ND-LotsGroupAwardCriterion[BT-540-LotsGroup is present] DISPLAY #{field|name|BT-540-LotsGroup}: ${if (BT-540-LotsGroup == 'unpublished') then '' else preferred-language-text(BT-540-LotsGroup)} #{${if (BT-540-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else ''}} ; // Award Criterion Description
					WITH BT-197(BT-540)-LotsGroup DISPLAY #{field|name|BT-197(BT-540)-LotsGroup}: #{BT-197(BT-540)-LotsGroup}; // Unpublished Justification Code
					WITH ND-LotsGroupAwardCriteriaNameUnpublish[BT-196(BT-540)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-540)-LotsGroup}: ${preferred-language-text(BT-196(BT-540)-LotsGroup)}; // Unpublished Justification Description
					WITH ND-LotsGroupAwardCriteriaNameUnpublish[BT-198(BT-540)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-540)-LotsGroup}: ${BT-198(BT-540)-LotsGroup}; // Unpublished Access Date
				0 WITH ND-LotsGroupAwardWeightCriterionParameter[BT-5421-LotsGroup is present] DISPLAY #{field|name|BT-5421-LotsGroup}: #{${if (BT-5421-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else concat('code|name|number-weight.', BT-5421-LotsGroup)}} ; // Award Criterion Number Weight Dimension
					WITH BT-197(BT-5421)-LotsGroup DISPLAY #{field|name|BT-197(BT-5421)-LotsGroup}: #{BT-197(BT-5421)-LotsGroup}; // Unpublished Justification Code
					WITH ND-LotsGroupAwardCriterionNumberWeightUnpublish[BT-196(BT-5421)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-5421)-LotsGroup}: ${preferred-language-text(BT-196(BT-5421)-LotsGroup)}; // Unpublished Justification Description
					WITH ND-LotsGroupAwardCriterionNumberWeightUnpublish[BT-198(BT-5421)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-5421)-LotsGroup}: ${BT-198(BT-5421)-LotsGroup}; // Unpublished Access Date
					0 WITH ND-LotsGroupAwardWeightCriterionParameter[BT-541-LotsGroup-WeightNumber is present] DISPLAY #{name|BT-541}: ${if (BT-541-LotsGroup-WeightNumber == -1) then '' else format-number(BT-541-LotsGroup-WeightNumber, '###,##0.###,###,###')} #{${if (BT-541-LotsGroup-WeightNumber == -1) then 'auxiliary|text|unpublished' else '' }} ; // Award Criterion Number
						WITH BT-197(BT-541)-LotsGroup-Weight DISPLAY #{field|name|BT-197(BT-541)-LotsGroup-Weight}: #{BT-197(BT-541)-LotsGroup-Weight}; // Unpublished Justification Code
						WITH ND-LotsGroupAwardCriterionWeightNumberUnpublish[BT-196(BT-541)-LotsGroup-Weight is present] DISPLAY #{field|name|BT-196(BT-541)-LotsGroup-Weight}: ${preferred-language-text(BT-196(BT-541)-LotsGroup-Weight)}; // Unpublished Justification Description
						WITH ND-LotsGroupAwardCriterionWeightNumberUnpublish[BT-198(BT-541)-LotsGroup-Weight is present] DISPLAY #{field|name|BT-198(BT-541)-LotsGroup-Weight}: ${BT-198(BT-541)-LotsGroup-Weight}; // Unpublished Access Date
				0 WITH ND-LotsGroupAwardFixedCriterionParameter[BT-5422-LotsGroup is present] DISPLAY #{field|name|BT-5422-LotsGroup}: #{${if (BT-5422-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else concat('code|name|number-fixed.', BT-5422-LotsGroup)}} ; // Award Criterion Number Fixed Dimension
					WITH BT-197(BT-5422)-LotsGroup DISPLAY #{field|name|BT-197(BT-5422)-LotsGroup}: #{BT-197(BT-5422)-LotsGroup}; // Unpublished Justification Code
					WITH ND-LotsGroupAwardCriterionNumberFixUnpublish[BT-196(BT-5422)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-5422)-LotsGroup}: ${preferred-language-text(BT-196(BT-5422)-LotsGroup)}; // Unpublished Justification Description
					WITH ND-LotsGroupAwardCriterionNumberFixUnpublish[BT-198(BT-5422)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-5422)-LotsGroup}: ${BT-198(BT-5422)-LotsGroup}; // Unpublished Access Date
					0 WITH ND-LotsGroupAwardFixedCriterionParameter[BT-541-LotsGroup-FixedNumber is present] DISPLAY #{name|BT-541}: ${if (BT-541-LotsGroup-FixedNumber == -1) then '' else format-number(BT-541-LotsGroup-FixedNumber, '###,##0.###,###,###')} #{${if (BT-541-LotsGroup-FixedNumber == -1) then 'auxiliary|text|unpublished' else '' }} ; // Award Criterion Number
						WITH BT-197(BT-541)-LotsGroup-Fixed DISPLAY #{field|name|BT-197(BT-541)-LotsGroup-Fixed}: #{BT-197(BT-541)-LotsGroup-Fixed}; // Unpublished Justification Code
						WITH ND-LotsGroupAwardCriterionFixNumberUnpublish[BT-196(BT-541)-LotsGroup-Fixed is present] DISPLAY #{field|name|BT-196(BT-541)-LotsGroup-Fixed}: ${preferred-language-text(BT-196(BT-541)-LotsGroup-Fixed)}; // Unpublished Justification Description
						WITH ND-LotsGroupAwardCriterionFixNumberUnpublish[BT-198(BT-541)-LotsGroup-Fixed is present] DISPLAY #{field|name|BT-198(BT-541)-LotsGroup-Fixed}: ${BT-198(BT-541)-LotsGroup-Fixed}; // Unpublished Access Date
				0 WITH ND-LotsGroupAwardThresholdCriterionParameter[BT-5423-LotsGroup is present] DISPLAY #{field|name|BT-5423-LotsGroup}: #{${if (BT-5423-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else concat('code|name|number-threshold.', BT-5423-LotsGroup)}} ; // Award Criterion Number Threshold Dimension
					WITH BT-197(BT-5423)-LotsGroup DISPLAY #{field|name|BT-197(BT-5423)-LotsGroup}: #{BT-197(BT-5423)-LotsGroup}; // Unpublished Justification Code
					WITH ND-LotsGroupAwardCriterionNumberThresholdUnpublish[BT-196(BT-5423)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-5423)-LotsGroup}: ${preferred-language-text(BT-196(BT-5423)-LotsGroup)}; // Unpublished Justification Description
					WITH ND-LotsGroupAwardCriterionNumberThresholdUnpublish[BT-198(BT-5423)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-5423)-LotsGroup}: ${BT-198(BT-5423)-LotsGroup}; // Unpublished Access Date
					0 WITH ND-LotsGroupAwardThresholdCriterionParameter[BT-541-LotsGroup-ThresholdNumber is present] DISPLAY #{name|BT-541}: ${if (BT-541-LotsGroup-ThresholdNumber == -1) then '' else format-number(BT-541-LotsGroup-ThresholdNumber, '###,##0.###,###,###')} #{${if (BT-541-LotsGroup-ThresholdNumber == -1) then 'auxiliary|text|unpublished' else '' }} ; // Award Criterion Number
						WITH BT-197(BT-541)-LotsGroup-Threshold DISPLAY #{field|name|BT-197(BT-541)-LotsGroup-Threshold}: #{BT-197(BT-541)-LotsGroup-Threshold}; // Unpublished Justification Code
						WITH ND-LotsGroupAwardCriterionThresholdNumberUnpublish[BT-196(BT-541)-LotsGroup-Threshold is present] DISPLAY #{field|name|BT-196(BT-541)-LotsGroup-Threshold}: ${preferred-language-text(BT-196(BT-541)-LotsGroup-Threshold)}; // Unpublished Justification Description
						WITH ND-LotsGroupAwardCriterionThresholdNumberUnpublish[BT-198(BT-541)-LotsGroup-Threshold is present] DISPLAY #{field|name|BT-198(BT-541)-LotsGroup-Threshold}: ${BT-198(BT-541)-LotsGroup-Threshold}; // Unpublished Access Date
			0 WITH ND-LotsGroupAwardCriteria[BT-543-LotsGroup is present] DISPLAY #{field|name|BT-543-LotsGroup}: ${if (BT-543-LotsGroup == 'unpublished') then '' else preferred-language-text(BT-543-LotsGroup)} #{${if (BT-543-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else ''}} ; // Award Criteria Complicated
				WITH BT-197(BT-543)-LotsGroup DISPLAY #{field|name|BT-197(BT-543)-LotsGroup}: #{BT-197(BT-543)-LotsGroup}; // Unpublished Justification Code
				WITH ND-LotsGroupAwardCriterionNumberComplicatedUnpublish[BT-196(BT-543)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-543)-LotsGroup}: ${preferred-language-text(BT-196(BT-543)-LotsGroup)}; // Unpublished Justification Description
				WITH ND-LotsGroupAwardCriterionNumberComplicatedUnpublish[BT-198(BT-543)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-543)-LotsGroup}: ${BT-198(BT-543)-LotsGroup}; // Unpublished Access Date
			0 WITH ND-LotsGroupAwardCriteria[BT-733-LotsGroup is present] DISPLAY #{field|name|BT-733-LotsGroup}: ${if (BT-733-LotsGroup == 'unpublished') then '' else preferred-language-text(BT-733-LotsGroup)} #{${if (BT-733-LotsGroup == 'unpublished') then 'auxiliary|text|unpublished' else ''}} ; // Award Criteria Order Justification
				WITH BT-197(BT-733)-LotsGroup DISPLAY #{field|name|BT-197(BT-733)-LotsGroup}: #{BT-197(BT-733)-LotsGroup}; // Unpublished Justification Code
				WITH ND-LotsGroupAwardCriteriaOrderJustificationUnpublish[BT-196(BT-733)-LotsGroup is present] DISPLAY #{field|name|BT-196(BT-733)-LotsGroup}: ${preferred-language-text(BT-196(BT-733)-LotsGroup)}; // Unpublished Justification Description
				WITH ND-LotsGroupAwardCriteriaOrderJustificationUnpublish[BT-198(BT-733)-LotsGroup is present] DISPLAY #{field|name|BT-198(BT-733)-LotsGroup}: ${BT-198(BT-733)-LotsGroup}; // Unpublished Access Date
5 WITH ND-Root[BT-137-Lot is present] DISPLAY #{auxiliary|text|lot}; // 5 Lots
	1 WITH ND-Lot, text:$lotid=BT-137-Lot DISPLAY #{field|name|BT-137-Lot}: ${BT-137-Lot} ; // 5.1 Lot
		WITH ND-Lot DISPLAY #{field|name|BT-21-Lot}: ${preferred-language-text(BT-21-Lot)}; // Title
		WITH ND-Lot DISPLAY #{field|name|BT-24-Lot}: ${preferred-language-text(BT-24-Lot)}; // Description
		WITH BT-22-Lot DISPLAY #{name}: $value; // Internal identifier
		1 WITH ND-LotProcurementScope[(BT-23-Lot is present) or (BT-26(m)-Lot is present) or (BT-26(a)-Lot is present) or (BT-25-Lot is present) or (BT-54-Lot is present)] DISPLAY #{auxiliary|text|purpose}; // 5.1.1 Purpose
			WITH BT-23-Lot DISPLAY #{name}: #value; // Nature of the contract
			WITH ND-LotProcurementScope[BT-531-Lot is present] DISPLAY #{field|name|BT-531-Lot}: #{BT-531-Lot}; // Additional Nature
			WITH BT-262-Lot[BT-26(m)-Lot == 'cpv'] DISPLAY #{name}( ${BT-26(m)-Lot}): ${BT-262-Lot} #{BT-262-Lot} ; // Main classification (CPV)
			WITH BT-263-Lot[BT-26(a)-Lot == 'cpv'] DISPLAY #{name}( ${BT-26(a)-Lot}): ${BT-263-Lot} #{BT-263-Lot} ; // Additional classification (CPV)
