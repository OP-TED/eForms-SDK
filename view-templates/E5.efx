6 WITH ND-NoticeResult DISPLAY #{auxiliary|text|results}; // 6 Results
	0 WITH BT-161-NoticeResult DISPLAY #{name}: ${if (BT-161-NoticeResult == -1) then '' else format-number(BT-161-NoticeResult, '###,##0.##')} #{${if (BT-161-NoticeResult == -1) then 'auxiliary|text|unpublished' else concat('code|name|currency.', BT-161-NoticeResult/@currencyID )}} ; // Notice Value (Value of all contracts awarded in this procedure)
