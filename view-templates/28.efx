				WITH ND-UBO[OPT-202-UBO[count(BT-706-UBO) > 1] == $uboid] DISPLAY #{field|name|BT-706-UBO}: ${BT-706-UBO}; // Beneficial Owner Nationality (more than one)
				WITH ND-UBO[BT-510(a)-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-510(a)-UBO}: ${concat(BT-510(a)-UBO, ' ', BT-510(b)-UBO, ' ', BT-510(c)-UBO)}; // Beneficial Owner Postal Address
				WITH ND-UBO[BT-513-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-513-UBO}: ${BT-513-UBO}; // Beneficial Owner City
				WITH ND-UBO[BT-512-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-512-UBO}: ${BT-512-UBO}; // Beneficial Owner Post Code
				WITH ND-UBO[BT-507-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-507-UBO}: #{BT-507-UBO} (${BT-507-UBO}) ; // Beneficial Owner Country Subdivision
				WITH ND-UBO[BT-514-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-514-UBO}: #{BT-514-UBO}; // Beneficial Owner Country
				WITH ND-UBO[BT-506-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-506-UBO}: ${BT-506-UBO}; // Beneficial Owner Contact Email Address
				WITH ND-UBO[BT-503-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-503-UBO}: ${BT-503-UBO}; // Beneficial Owner Telephone Number
				WITH ND-UBO[BT-739-UBO[OPT-202-UBO == $uboid] is present] DISPLAY #{field|name|BT-739-UBO}: ${BT-739-UBO}; // Beneficial Owner Fax
			WITH ND-Organization[some text:$lotswon1 in (for text:$orgid0 in OPT-200-Organization-Company[BT-746-Organization == TRUE], text:$tpaid in OPT-210-Tenderer[$orgid0 in OPT-300-Tenderer], text:$tenderid in OPT-321-Tender[OPT-310-Tender == $tpaid], text:$contractid in OPT-315-LotResult[$tenderid in BT-3202-Contract], text:$lotresultid in OPT-322-LotResult[$tenderid in OPT-320-LotResult[$contractid in OPT-315-LotResult]], text:$lotid in BT-13713-LotResult[OPT-322-LotResult == $lotresultid] return $lotid ) satisfies $lotswon1 != ''] DISPLAY #{field|name|BT-746-Organization}; // The winner is listed on a regulated market
10 WITH ND-Root[BT-758-notice is present] DISPLAY #{auxiliary|text|change}; // 10 Change
	WITH BT-758-notice DISPLAY #{name}: $value; // Change Notice Version Identifier
	WITH BT-140-notice DISPLAY #{name}: #value; // Change Reason Code
	WITH ND-ChangeReason[BT-762-notice is present] DISPLAY #{field|name|BT-762-notice}: ${BT-762-notice}; // Change Reason Description
	1 WITH ND-Change DISPLAY #{auxiliary|text|change}; // 10.1 Change
		WITH BT-13716-notice DISPLAY #{name}: $value; // Change Previous Section Identifier
		WITH ND-Change[BT-141(a)-notice is present] DISPLAY #{field|name|BT-141(a)-notice}: ${BT-141(a)-notice}; // Change Description
		WITH BT-719-notice DISPLAY #{field|name|BT-718-notice}: $value; // Change Procurement Documents / Change Procurement Documents Date
0 WITH ND-Root DISPLAY #{auxiliary|text|notice-information}; // Notice information
	WITH BT-701-notice DISPLAY #{name}: ${BT-701-notice} - ${BT-757-notice} ; // Notice identifier / version
	WITH BT-03-notice DISPLAY #{name}: #value; // Form type
	WITH BT-02-notice DISPLAY #{name}: #value; // Notice type
	WITH BT-05(a)-notice DISPLAY #{field|name|BT-05(a)-notice}: ${BT-05(a)-notice} ${BT-05(b)-notice} ; // Notice dispatch date and time
	WITH BT-803(d)-notice DISPLAY #{field|name|BT-803(d)-notice}: ${BT-803(d)-notice} ${BT-803(t)-notice} ; // Notice dispatch date (eSender)
	WITH BT-702(a)-notice DISPLAY #{field|name|BT-702(a)-notice}: #{BT-702(a)-notice} #{BT-702(b)-notice} ; // Languages in which this notice is officially available
	WITH OPP-010-notice DISPLAY #{name}: $value; // Notice publication number
	WITH OPP-011-notice DISPLAY #{name}: $value; // OJ S issue number
	WITH OPP-012-notice DISPLAY #{name}: $value; // Publication date
--- NAVIGATION --- // NAVIGATION
--- SUMMARY --- // SUMMARY
