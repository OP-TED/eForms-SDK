// View 11
// File generated from metadata database
let text:$myglobalvar=BT-701-notice;let $lot-by-lot-or-gol-id index BT-137-Lot by BT-137-Lot;let $lot-name-by-lot-or-gol-id index BT-21-Lot by BT-137-Lot;let indicator:?myfunc3()=TRUE; let indicator:?exists-common-value(text*:$seq1, text*:$seq2) = (count(value-intersect($seq1, $seq2)) > 0); let template:role-and-name(text:$label-id, text:$org-tpo-id) display #{${$label-id}}: ${BT-500-Organization-Company[OPT-200-Organization-Company == $org-tpo-id or $org-tpo-id in OPT-201-Organization-TouchPoint]:preferredLanguageText}${BT-500-Organization-TouchPoint[OPT-201-Organization-TouchPoint == $org-tpo-id]:preferredLanguageText};let template:mytemplate(text:$id) display ${BT-500-Organization-Company[OPT-200-Organization-Company == $id]:preferredLanguageText}; // GLOBALS // let $lot-name-by-gol-id index BT-21-Lot by ( for text:$this-lot-id in BT-137-Lot return BT-330-Procedure[ $this-lot-id in BT-1375-Procedure]);// let template:mytemplate(text:$id) display ${BT-500-Organization-Company[OPT-200-Organization-Company == $id]};// let template:mytemplate(text:$id) display ${efx:preferred-language-text(BT-500-Organization-Company[OPT-200-Organization-Company == $id])};// let context:$all-organisations = OPT-200-Organization-Company;// let text:?org-tpo-name(text:$id) = if ($id in OPT-201-Organization-TouchPoint) then concat(BT-500-Organization-Company[$id in OPT-201-Organization-TouchPoint], ' - ', BT-500-Organization-TouchPoint[$id in OPT-201-Organization-TouchPoint]) else BT-500-Organization-Company[$id in OPT-200-Organization-Company];// WITH BT-137-Lot[OPT-301-Lot-AddInfo is present], text:$refid = OPT-301-Lot-AddInfo, text*:$org_name = distinct-values(BT-500-Organization-Company[(OPT-200-Organization-Company == $refid) or ($refid in OPT-201-Organization-TouchPoint)]), text*:$tpo_names = distinct-values(BT-500-Organization-TouchPoint[OPT-201-Organization-TouchPoint == $refid]) DISPLAY #{auxiliary|text|organisation-providing-info-procedure}: ${$org_name}${if (count($tpo_names) > 0) then concat(' - ', $tpo_names[1]) else ''} ; // Organisation providing additional information about the procurement procedure (Lot)
1 WHEN OPT-300-Procedure-Buyer is present DISPLAY #{auxiliary|text|buyer}; // 1 Buyer
	1 WITH ND-ContractingParty DISPLAY #{auxiliary|text|buyer}; // 1.1 Buyer
		WITH ND-ContractingParty, text:$orgid=OPT-300-Procedure-Buyer DISPLAY #{field|name|BT-500-Organization-Company}: ${BT-500-Organization-Company:preferredLanguageText}; // Official name
		WITH BT-11-Procedure-Buyer DISPLAY #{name}: #value; // Legal type of the buyer
		WITH BT-10-Procedure-Buyer DISPLAY #{name}: #value; // Activity of the contracting authority
		WITH BT-610-Procedure-Buyer DISPLAY #{name}: #value; // Activity Entity
2 DISPLAY #{auxiliary|text|procedure}; // 2 Procedure
	1 WITH ND-ProcedureProcurementScope DISPLAY #{auxiliary|text|procedure}; // 2.1 Procedure
		WITH ND-ProcedureProcurementScope DISPLAY #{field|name|BT-21-Procedure}: ${BT-21-Procedure:preferredLanguageText}; // Procedure Title
		WITH ND-ProcedureProcurementScope DISPLAY #{field|name|BT-24-Procedure}: ${BT-24-Procedure:preferredLanguageText}; // Procedure Description
		WITH BT-04-notice DISPLAY #{name}: $value; // Procedure identifier
		WITH OPP-090-Procedure DISPLAY #{name}: $value; // Previous Notice
		WITH BT-22-Procedure DISPLAY #{name}: $value; // Internal identifier
		0 WITH BT-105-Procedure WHEN BT-105-Procedure:isMasked DISPLAY #{name}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY  #{name}: #{BT-105-Procedure}; // Type of the procedure
		0 WITH ND-ProcedureTenderingProcess[BT-88-Procedure is present] WHEN BT-88-Procedure:isMasked DISPLAY #{field|name|BT-88-Procedure}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-88-Procedure}: ${BT-88-Procedure:preferredLanguageText} ; // Procedure Features / Description of the procedure
		1 WITH ND-ProcedureProcurementScope[(BT-23-Procedure is present) or (BT-531-Procedure is present) or (BT-262-Procedure is present) or (BT-263-Procedure is present)] DISPLAY #{auxiliary|text|purpose}; // 2.1.1 Purpose
			WITH BT-23-Procedure DISPLAY #{field|name|BT-23-Procedure}: #{BT-23-Procedure}; // Nature of the contract
			WITH ND-ProcedureProcurementScope[BT-531-Procedure is present] DISPLAY #{field|name|BT-531-Procedure}: #{BT-531-Procedure}; // Additional nature of the contract
			WITH BT-262-Procedure[BT-26(m)-Procedure == 'cpv'] DISPLAY #{field|name|BT-262-Procedure}( ${BT-26(m)-Procedure}): ${BT-262-Procedure} #{BT-262-Procedure} ; // Main classification (CPV)
			WITH BT-263-Procedure[BT-26(a)-Procedure == 'cpv'] DISPLAY #{field|name|BT-263-Procedure}( ${BT-26(a)-Procedure}): ${BT-263-Procedure} #{BT-263-Procedure} ; // Additional classification (CPV)
		2 WITH ND-ProcedurePlacePerformance DISPLAY #{auxiliary|text|place-performance}; // 2.1.2 Place of performance
			WITH BT-5101(a)-Procedure DISPLAY #{name}: $value ${BT-5101(b)-Procedure} ${BT-5101(c)-Procedure} ; // Place Performance Postal address
			WITH BT-5131-Procedure DISPLAY #{name}: $value; // Place Performance Town
			WITH BT-5121-Procedure DISPLAY #{name}: $value; // Place Performance Post Code
			WITH BT-5071-Procedure DISPLAY #{name}: #{BT-5071-Procedure} ($value) ; // Place Performance Country Subdivision
			WITH BT-5141-Procedure DISPLAY #{name}: #value; // Place Performance Country
			WITH BT-727-Procedure DISPLAY #{BT-727-Procedure}; // Place Performance Services Other
			WITH ND-ProcedurePlacePerformanceAdditionalInformation[BT-728-Procedure is present] DISPLAY #{field|name|BT-728-Procedure}: ${BT-728-Procedure:preferredLanguageText}; // Place Performance Additional information
		3 WITH ND-ProcedureProcurementScope[(BT-27-Procedure is present) or (BT-271-Procedure is present)] DISPLAY #{auxiliary|text|value}; // 2.1.3 Value
			WITH BT-27-Procedure DISPLAY #{name}: ${format-number(BT-27-Procedure, '###,##0.##')} #{code|name|${concat('currency.', BT-27-Procedure/@currencyID)}} ; // Estimated value
			WITH BT-271-Procedure DISPLAY #{name}: ${format-number(BT-271-Procedure, '###,##0.##')} #{code|name|${concat('currency.', BT-271-Procedure/@currencyID)}} ; // Estimated Framework Maximum Value
		4 WITH ND-ProcedureProcurementScope[BT-01-notice is present] DISPLAY #{auxiliary|text|general-information}; // 2.1.4 General information
			WITH BT-634-Procedure[BT-634-Procedure == TRUE] DISPLAY #{name}; // Procurement Relaunch
			WITH ND-ProcedureProcurementScope[BT-300-Procedure is present] DISPLAY #{field|name|BT-300-Procedure}: ${BT-300-Procedure:preferredLanguageText}; // Additional information
			WITH ND-ProcedureProcurementScope DISPLAY #{auxiliary|text|legal-basis}:; // Legal basis
			WITH BT-01-notice DISPLAY #{BT-01-notice}; // Procedure Legal Basis
			WITH BT-01(c)-Procedure DISPLAY $value - ${BT-01(d)-Procedure:preferredLanguageText}; // Procedure Legal Basis (ID) - Procedure Legal Basis (Description)
			WITH BT-01(e)-Procedure DISPLAY ${BT-01(f)-Procedure:preferredLanguageText}; // Procedure Legal Basis (no ID) Description
			0 WITH BT-09(a)-Procedure WHEN BT-09(b)-Procedure:isMasked DISPLAY #{auxiliary|text|cross-border-law}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{auxiliary|text|cross-border-law}: ${BT-09(b)-Procedure:preferredLanguageText} ; // Applicable cross-border law
		5 WITH ND-Root[BT-31-Procedure is present or BT-763-Procedure is present or BT-33-Procedure is present] DISPLAY #{auxiliary|text|procurement-terms}; // 2.1.5 Procurement terms
			0 WITH ND-Root[BT-31-Procedure is present or BT-763-Procedure is present] DISPLAY #{auxiliary|text|submission-terms}:; // Terms of submission
				WITH BT-31-Procedure DISPLAY #{name}: ${format-number(BT-31-Procedure, '###,##0')}; // Maximum number of lots for which one tenderer can submit tenders
				WITH BT-763-Procedure [BT-763-Procedure == 'all'] DISPLAY #{field|name|BT-763-Procedure}; // The tenderer must submit tenders for all lots. (indicator all)
			0 WITH ND-Root[BT-33-Procedure is present] DISPLAY #{auxiliary|text|contract-terms}:; // Terms of contract
				WITH BT-33-Procedure DISPLAY #{name}: ${format-number(BT-33-Procedure, '###,##0')}; // Maximum number of lots for which contracts can be awarded to one tenderer
		6 WITH ND-ProcedureTerms[(BT-67(a)-Procedure is present) or (BT-806-Procedure is present)] DISPLAY #{auxiliary|text|exclusion-grounds}; // 2.1.6 Exclusion grounds
			WITH ND-ProcedureTerms[(BT-806-Procedure is present)] DISPLAY #{auxiliary|text|exclusion-grounds-sources}: #{BT-806-Procedure}; // Exclusion grounds sources
			WITH BT-67(a)-Procedure DISPLAY #{BT-67(a)-Procedure}: ${BT-67(b)-Procedure:preferredLanguageText}; // Description
4 WITH ND-Root[BT-137-LotsGroup is present] DISPLAY #{auxiliary|text|group-of-lots}; // 4 Group of lots
	1 WITH ND-LotsGroup DISPLAY #{field|name|BT-330-Procedure}: ${BT-137-LotsGroup}; // 4.1 Group of lots
		WITH BT-137-LotsGroup DISPLAY #{field|name|BT-1375-Procedure}: ${for text:$gloid in BT-137-LotsGroup return BT-1375-Procedure[BT-330-Procedure == $gloid]}; // Lots included / Group Lot Identifier 
		WITH BT-137-LotsGroup[BT-21-LotsGroup is present] DISPLAY #{field|name|BT-21-LotsGroup}: ${BT-21-LotsGroup:preferredLanguageText}; // Title of LotsGroup
		WITH BT-137-LotsGroup[BT-24-LotsGroup is present] DISPLAY #{field|name|BT-24-LotsGroup}: ${BT-24-LotsGroup:preferredLanguageText}; // Description of LotsGroup
		WITH BT-22-LotsGroup DISPLAY #{name}: $value; // Internal identifier of LotsGroup
		1 WITH BT-137-LotsGroup[(BT-27-LotsGroup is present) or (BT-271-LotsGroup is present) or (BT-157-LotsGroup is present)] DISPLAY #{auxiliary|text|value}; // 4.1.1 Value
			WITH BT-27-LotsGroup DISPLAY #{name}: ${format-number(BT-27-LotsGroup, '###,##0.##')} #{code|name|${concat('currency.', BT-27-LotsGroup/@currencyID)}} ; // Estimated value
			WITH BT-271-LotsGroup DISPLAY #{name}: ${format-number(BT-271-LotsGroup, '###,##0.##')} #{code|name|${concat('currency.', BT-271-LotsGroup/@currencyID)}} ; // Framework Maximum Value
			WITH BT-157-LotsGroup DISPLAY #{name}: ${format-number(BT-157-LotsGroup, '###,##0.##')} #{code|name|${concat('currency.', BT-157-LotsGroup/@currencyID)}} ; // Maximum value of the framework agreement within the group of lots
		2 WITH ND-LotsGroupProcurementScope[BT-300-LotsGroup is present] DISPLAY #{auxiliary|text|general-information}; // 4.1.2 General information
			WITH BT-137-LotsGroup[BT-300-LotsGroup is present] DISPLAY #{field|name|BT-300-LotsGroup}: ${BT-300-LotsGroup:preferredLanguageText}; // Additional information
			WITH BT-726-LotsGroup DISPLAY #{name}: #{${if (BT-726-LotsGroup == TRUE) then 'code|name|indicator.true' else 'code|name|indicator.false'}} ; // This procurement is also suitable for small and medium enterprises (SMEs). (true / false)
		3 WITH ND-LotsGroupAwardCriteria DISPLAY #{auxiliary|text|award-criteria}; // 4.1.3 Award criteria
			0 WITH ND-LotsGroupAwardCriterion DISPLAY #{auxiliary|text|criterion}:; // Criterion
				0 WITH ND-LotsGroupAwardCriterion[BT-539-LotsGroup is present ] WHEN BT-539-LotsGroup:isMasked DISPLAY #{field|name|BT-539-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-539-LotsGroup}: #{BT-539-LotsGroup} ; // Criterion Type
				0 WITH ND-LotsGroupAwardCriterion[BT-734-LotsGroup is present] WHEN BT-734-LotsGroup:isMasked DISPLAY #{field|name|BT-734-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-734-LotsGroup}: ${BT-734-LotsGroup:preferredLanguageText} ; // Criterion Name
				0 WITH ND-LotsGroupAwardCriterion[BT-540-LotsGroup is present] WHEN BT-540-LotsGroup:isMasked DISPLAY #{field|name|BT-540-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-540-LotsGroup}: ${BT-540-LotsGroup:preferredLanguageText} ; // Award Criterion Description
				0 WITH ND-LotsGroupAwardWeightCriterionParameter[BT-5421-LotsGroup is present] WHEN BT-5421-LotsGroup:isMasked DISPLAY #{field|name|BT-5421-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-5421-LotsGroup}: #{BT-5421-LotsGroup} ; // Award Criterion Number Weight Dimension
					0 WITH ND-LotsGroupAwardWeightCriterionParameter[BT-541-LotsGroup-WeightNumber is present] WHEN BT-541-LotsGroup-WeightNumber:isMasked DISPLAY #{name|BT-541}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{name|BT-541}: ${format-number(BT-541-LotsGroup-WeightNumber, '###,##0.###,###,###')} ; // Award Criterion Number
				0 WITH ND-LotsGroupAwardFixedCriterionParameter[BT-5422-LotsGroup is present] WHEN BT-5422-LotsGroup:isMasked DISPLAY #{field|name|BT-5422-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-5422-LotsGroup}: #{BT-5422-LotsGroup} ; // Award Criterion Number Fixed Dimension
					0 WITH ND-LotsGroupAwardFixedCriterionParameter[BT-541-LotsGroup-FixedNumber is present] WHEN BT-541-LotsGroup-FixedNumber:isMasked DISPLAY #{name|BT-541}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{name|BT-541}: ${format-number(BT-541-LotsGroup-FixedNumber, '###,##0.###,###,###')} ; // Award Criterion Number
				0 WITH ND-LotsGroupAwardThresholdCriterionParameter[BT-5423-LotsGroup is present] WHEN BT-5423-LotsGroup:isMasked DISPLAY #{field|name|BT-5423-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-5423-LotsGroup}: #{BT-5423-LotsGroup} ; // Award Criterion Number Threshold Dimension
					0 WITH ND-LotsGroupAwardThresholdCriterionParameter[BT-541-LotsGroup-ThresholdNumber is present] WHEN BT-541-LotsGroup-ThresholdNumber:isMasked DISPLAY #{name|BT-541}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{name|BT-541}: ${format-number(BT-541-LotsGroup-ThresholdNumber, '###,##0.###,###,###')} ; // Award Criterion Number
			0 WITH ND-LotsGroupAwardCriteria[BT-543-LotsGroup is present] WHEN BT-543-LotsGroup:isMasked DISPLAY #{field|name|BT-543-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-543-LotsGroup}: ${BT-543-LotsGroup:preferredLanguageText} ; // Award Criteria Complicated
			0 WITH ND-LotsGroupAwardCriteria[BT-733-LotsGroup is present] WHEN BT-733-LotsGroup:isMasked DISPLAY #{field|name|BT-733-LotsGroup}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-733-LotsGroup}: ${BT-733-LotsGroup:preferredLanguageText} ; // Award Criteria Order Justification
5 WITH ND-Root[BT-137-Lot is present] DISPLAY #{auxiliary|text|lot}; // 5 Lots
	1 WITH ND-Lot, text:$lotid=BT-137-Lot DISPLAY #{field|name|BT-137-Lot}: ${BT-137-Lot} ; // 5.1 Lot
		WITH ND-Lot DISPLAY #{field|name|BT-21-Lot}: ${BT-21-Lot:preferredLanguageText}; // Title
		WITH ND-Lot DISPLAY #{field|name|BT-24-Lot}: ${BT-24-Lot:preferredLanguageText}; // Description
		WITH BT-22-Lot DISPLAY #{name}: $value; // Internal identifier
		1 WITH ND-LotProcurementScope[(BT-23-Lot is present) or (BT-26(m)-Lot is present) or (BT-26(a)-Lot is present) or (BT-25-Lot is present) or (BT-54-Lot is present)] DISPLAY #{auxiliary|text|purpose}; // 5.1.1 Purpose
			WITH BT-23-Lot DISPLAY #{name}: #value; // Nature of the contract
			WITH ND-LotProcurementScope[BT-531-Lot is present] DISPLAY #{field|name|BT-531-Lot}: #{BT-531-Lot}; // Additional Nature
			WITH BT-262-Lot[BT-26(m)-Lot == 'cpv'] DISPLAY #{name}( ${BT-26(m)-Lot}): ${BT-262-Lot} #{BT-262-Lot} ; // Main classification (CPV)
			WITH BT-263-Lot[BT-26(a)-Lot == 'cpv'] DISPLAY #{name}( ${BT-26(a)-Lot}): ${BT-263-Lot} #{BT-263-Lot} ; // Additional classification (CPV)
			WITH BT-25-Lot DISPLAY #{name}: ${format-number(BT-25-Lot, '###,##0.###,###,###')} #{BT-625-Lot} ; // Quantity
			0 WITH ND-OptionsAndRenewals[BT-54-Lot is present] DISPLAY #{auxiliary|text|options}:; // Options
				WITH ND-OptionsAndRenewals DISPLAY #{field|name|BT-54-Lot}: ${BT-54-Lot:preferredLanguageText}; // The buyer reserves the right for additional purchases, described here, from the contractor
		2 WITH ND-LotPlacePerformance DISPLAY #{auxiliary|text|place-performance}; // 5.1.2 Place of performance
			WITH BT-5101(a)-Lot DISPLAY #{field|name|BT-5101(a)-Lot}: ${BT-5101(a)-Lot} ${BT-5101(b)-Lot} ${BT-5101(c)-Lot} ; // Postal address
			WITH BT-5131-Lot DISPLAY #{name}: $value; // Town
			WITH BT-5121-Lot DISPLAY #{name}: $value; // Post Code
			WITH BT-5071-Lot DISPLAY #{name}: #{BT-5071-Lot} ($value) ; // Country Subdivision
			WITH BT-5141-Lot DISPLAY #{name}: #value; // Country
			WITH BT-727-Lot DISPLAY #{BT-727-Lot}; // Restrictions on the place of performance
			WITH ND-LotPlacePerformance DISPLAY #{field|name|BT-728-Lot}: ${BT-728-Lot:preferredLanguageText}; // Additional information
		3 WITH ND-LotDuration DISPLAY #{auxiliary|text|estimated-duration}; // 5.1.3 Estimated duration
			WITH BT-536-Lot DISPLAY #{name}: $value; // Start date
			WITH BT-537-Lot DISPLAY #{name}: $value; // End date
			WITH BT-36-Lot DISPLAY #{name}: ${format-number(OPA-36-Lot-Number, '###,##0.###,###,###')} #{code|name|${concat('duration-unit.', BT-36-Lot/@unitCode)}} ; // Duration
			WITH BT-538-Lot DISPLAY #{name}: #value; // Planned Period (Unlimited)
		4 WITH ND-OptionsAndRenewals[(BT-57-Lot is present) or (BT-58-Lot is present)] DISPLAY #{auxiliary|text|renewal}; // 5.1.4 Renewal
			WITH BT-58-Lot DISPLAY #{name}: $value; // Maximum renewals
			WITH ND-OptionsAndRenewals[BT-57-Lot is present] DISPLAY #{field|name|BT-57-Lot}: ${BT-57-Lot:preferredLanguageText}; // Description
		5 WITH ND-LotValueEstimate[(BT-27-Lot is present) or (BT-271-Lot is present)] DISPLAY #{auxiliary|text|value}; // 5.1.5 Value
			WITH BT-27-Lot DISPLAY #{name}: ${format-number(BT-27-Lot, '###,##0.##')} #{code|name|${concat('currency.', BT-27-Lot/@currencyID)}} ; // Estimated value
			WITH BT-271-Lot DISPLAY #{name}: ${format-number(BT-271-Lot, '###,##0.##')} #{code|name|${concat('currency.', BT-271-Lot/@currencyID)}} ; // Framework Maximum Value
		6 WITH ND-Lot[(BT-634-Lot == TRUE) or (BT-94-Lot == TRUE) or (BT-95-Lot is present) or (BT-71-Lot is present) or (BT-79-Lot is present) or (BT-60-Lot is present) or (BT-7220-Lot is present) or (BT-5010-Lot is present) or (BT-6140-Lot is present) or (BT-115-Lot is present) or (BT-726-Lot == TRUE) or (BT-125(i)-Lot is present) or (BT-1251-Lot is present) or (BT-300-Lot is present)] DISPLAY #{auxiliary|text|general-information}; // 5.1.6 General information
			WITH BT-634-Lot[BT-634-Lot == TRUE] DISPLAY #{name}; // This cancelled or unsuccessful procedure or lot will be relaunched (only true allowed).
			WITH BT-137-Lot[BT-71-Lot is present] DISPLAY #{field|name|BT-71-Lot}: #{BT-71-Lot}; // Reserved Participation
			WITH BT-79-Lot DISPLAY #{name}: #value; // Performing Staff Qualification
			WITH BT-60-Lot DISPLAY #{BT-60-Lot}; // EU Funds
			0 WITH ND-Funding DISPLAY #{auxiliary|text|eu-funds-used}; // EU Funds Information
				WITH BT-7220-Lot DISPLAY #{name}: #value; // EU Funds Programme
				WITH BT-5010-Lot DISPLAY #{name}: $value; // EU Funds Financing Identifier
				WITH ND-Funding[BT-6140-Lot is present] DISPLAY #{field|name|BT-6140-Lot}: ${BT-6140-Lot:preferredLanguageText}; // EU Funds Details
			WITH BT-115-Lot DISPLAY #{name}: #{code|name|${if (BT-115-Lot == TRUE) then 'indicator.true' else 'indicator.false'}} ; // GPA Coverage
			WITH BT-726-Lot DISPLAY #{name}: #{${if (BT-726-Lot == TRUE) then 'code|name|indicator.true' else 'code|name|indicator.false'}} ; // This procurement is also suitable for small and medium enterprises (SMEs). (true / false)
			0 WITH ND-LotTenderingProcess[(BT-125(i)-Lot is present) or (BT-1251-Lot is present)] DISPLAY #{auxiliary|text|previous-planning}:; // Information about previous notices - Previous planning
				0 WITH BT-125(i)-Lot DISPLAY #{field|name|BT-125(i)-Lot}: ${BT-125(i)-Lot}; // Identifier of previous notice
					WITH BT-1251-Lot DISPLAY #{name}: $value; // Identifier of the part of the previous notice
			WITH BT-137-Lot[BT-300-Lot is present] DISPLAY #{field|name|BT-300-Lot}: ${BT-300-Lot:preferredLanguageText}; // Additional information
		7 WITH ND-LotProcurementScope[(BT-06-Lot is present) or (BT-777-Lot is present) or (BT-774-Lot is present) or (BT-775-Lot is present) or (BT-776-Lot is present) or (BT-805-Lot is present) or (BT-717-Lot is present) or (BT-810-Lot == 'true')] DISPLAY #{auxiliary|text|strategic-procurement}; // 5.1.7 Strategic procurement
			0 WITH ND-StrategicProcurementType DISPLAY #{field|name|BT-06-Lot}: #{BT-06-Lot}; // Aim of strategic procurement
				WITH BT-06-Lot[BT-777-Lot is present] DISPLAY #{field|name|BT-777-Lot}: ${for text:$spcode in BT-06-Lot, text:$spdesc in BT-777-Lot[BT-06-Lot == $spcode] return $spdesc}; // Description
			WITH ND-LotProcurementScope[BT-774-Lot is present] DISPLAY #{field|name|BT-774-Lot}: #{BT-774-Lot}; // Approach to reducing environmental impacts
			WITH ND-LotProcurementScope[BT-805-Lot is present] DISPLAY #{field|name|BT-805-Lot}: #{BT-805-Lot}; // Green Procurement Criteria
			WITH ND-LotProcurementScope[BT-775-Lot is present] DISPLAY #{field|name|BT-775-Lot}: #{BT-775-Lot}; // Social Procurement
			WITH ND-LotProcurementScope[BT-776-Lot is present] DISPLAY #{field|name|BT-776-Lot}: #{BT-776-Lot}; // Procurement of Innovation
			0 WITH ND-StrategicProcurementLot[BT-717-Lot == 'true'] DISPLAY #{field|name|BT-717-Lot}; // Clean Vehicles Directive
				WITH ND-StrategicProcurementLot[BT-735-Lot is present] DISPLAY #{field|name|BT-735-Lot} #{BT-735-Lot}; // CVD Contract Type
			0 WITH ND-EEDLot[BT-810-Lot == 'true'] DISPLAY #{auxiliary|text|eed-applicable}; // EED Applicable
				0 WITH ND-EEDInformationLot DISPLAY #{auxiliary|text|eed-list}; // EED Product List
					WITH BT-811(b)-Lot[BT-811(a)-Lot is present] DISPLAY #{BT-811(b)-Lot} (#{BT-811(a)-Lot}) ; // EED Item (with EED legal basis)
					WITH BT-811(b)-Lot[BT-811(a)-Lot is not present] DISPLAY #{BT-811(b)-Lot}; // EED Item (without EED legal basis)
		8 WITH ND-AccessibilityJustification DISPLAY #{auxiliary|text|accessibility}; // 5.1.8 Accessibility criteria
			WITH BT-754-Lot DISPLAY #{BT-754-Lot}; // Accessibility 
			WITH BT-137-Lot[BT-755-Lot is present] DISPLAY #{field|name|BT-755-Lot}: ${BT-755-Lot:preferredLanguageText}; // Accessibility Justification
		9 WITH ND-LotTenderingTerms[(BT-809-Lot is present) or (BT-821-Lot is present)] DISPLAY #{auxiliary|text|selection-criteria}; // 5.1.9 Selection criteria
			0 WITH ND-LotTenderingTerms[BT-821-Lot is present] DISPLAY #{auxiliary|text|selection-criteria-sources}: #{BT-821-Lot}; // Selection criteria sources
			0 WITH ND-SelectionCriteria DISPLAY #{auxiliary|text|criterion}: #{BT-809-Lot}; // Criterion
				WITH ND-SelectionCriteria[BT-750-Lot is present] DISPLAY #{field|name|BT-750-Lot}: ${BT-750-Lot:preferredLanguageText}; // Selection Criterion Description
				WITH BT-40-Lot[BT-40-Lot == TRUE] DISPLAY #{name}; // Selection Criteria Second Stage Invite
				WITH BT-7531-Lot DISPLAY #{BT-7531-Lot}: ${format-number(BT-752-Lot-WeightNumber, '###,##0.###,###,###')}; // Number Weight
				WITH BT-7532-Lot DISPLAY #{BT-7532-Lot}: ${format-number(BT-752-Lot-ThresholdNumber, '###,##0.###,###,###')}; // Number Threshold
			0 WITH ND-LotTenderingTerms[(BT-50-Lot is present) or (BT-51-Lot is present) or (BT-52-Lot == TRUE) or (BT-120-Lot == TRUE)] DISPLAY #{auxiliary|text|second-stage}:; // Information about the second stage of a two-stage procedure
