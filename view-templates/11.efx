				WITH BT-78-Lot DISPLAY #{name}: $value; // Security Clearance Deadline
			0 WITH ND-LotTenderingTerms[(BT-42-Lot is present) or (BT-46-Lot is present) or (BT-47-Lot is present) or (BT-644-Lot is present) or (BT-44-Lot is present) or (BT-41-Lot == TRUE) or (BT-45-Lot is present)] DISPLAY #{auxiliary|text|design-contest-terms}:; // Terms of the design contest regime
				0 WITH ND-Prize DISPLAY #{auxiliary|text|prize-information}; // Prize information
					WITH BT-644-Lot DISPLAY #{name}: ${format-number(BT-644-Lot, '###,##0.##')} #{code|name|${concat('currency.', BT-644-Lot/@currencyID)}} ; // Value of the prize
					WITH BT-44-Lot DISPLAY #{name}: $value; // Prize rank
					WITH ND-Prize[BT-45-Lot is present] DISPLAY #{field|name|BT-45-Lot}: ${BT-45-Lot:preferredLanguageText}; // Additional information
			0 WITH BT-137-Lot[(BT-651-Lot is present) or (BT-17-Lot is present) or (BT-18-Lot is present) or (BT-19-Lot is present) or (BT-745-Lot is present) or (BT-97-Lot is present) or (BT-764-Lot is present) or (BT-744-Lot is present) or (BT-63-Lot is present) or (BT-769-Lot is present) or (BT-75-Lot is present) or (BT-630(d)-Lot is present) or (BT-1311(d)-Lot is present) or (BT-131(d)-Lot is present) or (BT-98-Lot is present)] DISPLAY #{auxiliary|text|submission-terms}:; // Terms of submission
				WITH BT-17-Lot DISPLAY #{name}: #value; // Electronic submission
				WITH BT-18-Lot DISPLAY #{name}: $value; // Address for submission (URL)
				WITH BT-19-Lot DISPLAY #{name}: #value; // Submission Nonelectronic Justification
				WITH ND-NonEsubmission[BT-745-Lot is present] DISPLAY #{field|name|BT-745-Lot}: ${BT-745-Lot:preferredLanguageText}; // Submission Nonelectronic Description
				WITH BT-137-Lot[BT-97-Lot is present] DISPLAY #{field|name|BT-97-Lot}: #{BT-97-Lot}; // Languages in which tenders or requests to participate may be submitted
				WITH BT-764-Lot DISPLAY #{name}: #value; // Electronic catalogue
				WITH BT-744-Lot[BT-744-Lot == 'true'] DISPLAY #{name}; // Advanced or qualified electronic signature or seal (as defined in Regulation (EU) No 910/2014) is required. (true/false)
				WITH BT-63-Lot DISPLAY #{name}: #value; // Variants
				WITH BT-769-Lot DISPLAY #{name}: #value; // Tenderers may submit more than one tender.
				WITH BT-751-Lot[BT-75-Lot is present] DISPLAY #{field|name|BT-75-Lot}: ${BT-75-Lot:preferredLanguageText}; // Financial Guarantee Description
				WITH BT-630(d)-Lot DISPLAY #{field|name|BT-630(d)-Lot}: ${BT-630(d)-Lot} ${BT-630(t)-Lot} ; // Deadline for receipt of expressions of interest
				WITH BT-98-Lot DISPLAY #{name}: ${OPA-98-Lot-Number} #{code|name|${concat('duration-unit.', BT-98-Lot/@unitCode)}} ; // Deadline until which the tender must remain valid
			0 WITH ND-LateTendererInformation[(BT-771-Lot is present) and (BT-772-Lot is present)] DISPLAY #{auxiliary|text|late-tenderer-info}:; // Information that can be supplemented after the submission deadline
				WITH BT-771-Lot DISPLAY #{BT-771-Lot}; // Late Tenderer Information
				WITH ND-LateTendererInformation[BT-772-Lot is present] DISPLAY #{field|name|BT-772-Lot}: ${BT-772-Lot:preferredLanguageText}; // Late Tenderer Information Description
			0 WITH ND-LotTenderingTerms[(BT-736-Lot is present) or (BT-70-Lot is present) or (BT-801-Lot is present) or (BT-743-Lot is present) or (BT-92-Lot is present) or (BT-93-Lot is present) or (BT-76-Lot is present) or (BT-77-Lot is present) or (BT-65-Lot is present) or (BT-64-Lot is present) or (BT-729-Lot is present) or (BT-681-Lot == 'true') or (BT-684-Lot == 'true')] DISPLAY #{auxiliary|text|contract-terms}:; // Terms of contract
				WITH BT-736-Lot DISPLAY #{name}: #value; // The execution of the contract must be performed in the framework of sheltered employment programmes (yes / no / not-known)
				WITH ND-ExecutionRequirements[BT-70-Lot is present] DISPLAY #{field|name|BT-70-Lot}: ${BT-70-Lot:preferredLanguageText}; // Terms Performance
				0 WITH BT-801-Lot DISPLAY #{name}: #{${concat('code|name|indicator.', BT-801-Lot)}} ; // A non-disclosure agreement is required.
					WITH ND-NDA[BT-802-Lot is present] DISPLAY #{field|name|BT-802-Lot}: ${BT-802-Lot:preferredLanguageText}; // Additional information about the non-disclosure agreement
				WITH BT-681-Lot[BT-681-Lot == 'true'] DISPLAY #{auxiliary|text|foreign-subsidies-regulation}; // Foreign Subsidy Regulation (FSR)
				WITH BT-743-Lot DISPLAY #{name}: #value; // Electronic invoicing
				WITH BT-92-Lot DISPLAY #{name}: #{${if (BT-92-Lot == TRUE) then 'code|name|indicator.true' else 'code|name|indicator.false'}} ; // Electronic ordering will be used (true / false)
				WITH BT-93-Lot DISPLAY #{name}: #{${if (BT-93-Lot == TRUE) then 'code|name|indicator.true' else 'code|name|indicator.false'}} ; // Electronic payment will be used (true/false)
				WITH BT-761-Lot[(BT-76-Lot is present)] DISPLAY #{field|name|BT-76-Lot}: ${BT-76-Lot:preferredLanguageText}; // Legal form that must be taken by a group of tenderers that is awarded a contract
				WITH ND-PaymentTerms[BT-77-Lot is present] DISPLAY #{field|name|BT-77-Lot}: ${BT-77-Lot}; // Financial arrangement
		15 WITH ND-LotTenderingProcess[(BT-765-Lot is present) or (BT-113-Lot is present) or (BT-109-Lot is present) or (BT-111-Lot is present) or (BT-766-Lot is present) or (TRUE in BT-119-LotResult) or (BT-123-Lot is present) or (BT-122-Lot is present)] DISPLAY #{auxiliary|text|techniques}; // 5.1.15 Techniques
			0 WITH ND-LotTenderingProcess[(BT-765-Lot is present) or (BT-113-Lot is present) or (BT-109-Lot is present) or (BT-111-Lot is present)] DISPLAY #{auxiliary|text|framework-agreement}:; // Information about framework agreement
				WITH BT-765-Lot DISPLAY #{BT-765-Lot}; // Framework Agreement Type
				WITH BT-113-Lot DISPLAY #{name}: $value; // Maximum number of participants
				WITH BT-137-Lot[BT-109-Lot is present] DISPLAY #{field|name|BT-109-Lot}: ${BT-109-Lot:preferredLanguageText}; // Justification for the duration of framework agreement
