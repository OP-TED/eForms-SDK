				0 WITH ND-LotAwardCriterion[BT-734-Lot is present] WHEN BT-734-Lot:isMasked DISPLAY #{field|name|BT-734-Lot}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-734-Lot}: ${BT-734-Lot:preferredLanguageText} ; // Criterion Name
				0 WITH ND-LotAwardCriterion[BT-540-Lot is present] WHEN BT-540-Lot:isMasked DISPLAY #{field|name|BT-540-Lot}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-540-Lot}: ${BT-540-Lot:preferredLanguageText} ; // Award Criterion Description
				0 WITH ND-LotAwardWeightCriterionParameter[BT-5421-Lot is present] WHEN BT-5421-Lot:isMasked DISPLAY #{field|name|BT-5421-Lot}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-5421-Lot}: #{BT-5421-Lot} ; // Award Criterion Number Weight Dimension
					0 WITH ND-LotAwardWeightCriterionParameter[BT-541-Lot-WeightNumber is present] WHEN BT-541-Lot-WeightNumber:isMasked DISPLAY #{name|BT-541}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{name|BT-541}: ${format-number(BT-541-Lot-WeightNumber, '###,##0.###,###,###')} ; // Award Criterion Number
				0 WITH ND-LotAwardFixedCriterionParameter[BT-5422-Lot is present] WHEN BT-5422-Lot:isMasked DISPLAY #{field|name|BT-5422-Lot}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-5422-Lot}: #{BT-5422-Lot} ; // Award Criterion Number Fixed Dimension
					0 WITH ND-LotAwardFixedCriterionParameter[BT-541-Lot-FixedNumber is present] WHEN BT-541-Lot-FixedNumber:isMasked DISPLAY #{name|BT-541}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{name|BT-541}: ${format-number(BT-541-Lot-FixedNumber, '###,##0.###,###,###')} ; // Award Criterion Fixed Number
				0 WITH ND-LotAwardThresholdCriterionParameter[BT-5423-Lot is present] WHEN BT-5423-Lot:isMasked DISPLAY #{field|name|BT-5423-Lot}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-5423-Lot}: #{BT-5423-Lot} ; // Award Criterion Number Threshold Dimension
					0 WITH ND-LotAwardThresholdCriterionParameter[BT-541-Lot-ThresholdNumber is present] WHEN BT-541-Lot-ThresholdNumber:isMasked DISPLAY #{name|BT-541}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{name|BT-541}: ${format-number(BT-541-Lot-ThresholdNumber, '###,##0.###,###,###')} ; // Award Criterion Threshold Number
			0 WITH ND-LotAwardCriteria[BT-543-Lot is present] WHEN BT-543-Lot:isMasked DISPLAY #{field|name|BT-543-Lot}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-543-Lot}: ${BT-543-Lot:preferredLanguageText} ; // Award Criteria Complicated
			0 WITH ND-LotAwardCriteria[BT-733-Lot is present] WHEN BT-733-Lot:isMasked DISPLAY #{field|name|BT-733-Lot}: #{auxiliary|text|unpublished} OTHERWISE DISPLAY #{field|name|BT-733-Lot}: ${BT-733-Lot:preferredLanguageText} ; // Award Criteria Order Justification
		11 WITH BT-137-Lot[(BT-14-Lot is present) or (BT-632-Lot is present) or (BT-124-Lot is present)] DISPLAY #{auxiliary|text|procurement-documents}; // 5.1.11 Procurement documents
			WITH BT-137-Lot[some text:$restricted in (for text:$somerestricted in BT-14-Lot return $somerestricted) satisfies $restricted == 'restricted-document'] DISPLAY #{field|name|BT-14-Lot}; // The access to certain procurement documents is restricted. (Lot)
			WITH BT-707-Lot DISPLAY #{name}: #value; // Justification for restricting access to certain procurement documents (Lot)
			WITH BT-137-Lot[(BT-708-Lot is present)] DISPLAY #{field|name|BT-708-Lot}: #{BT-708-Lot}; // Languages in which the procurement documents are officially available (Lot)
			WITH BT-137-Lot[BT-737-Lot is present] DISPLAY #{field|name|BT-737-Lot}: #{BT-737-Lot}; // Languages in which the procurement documents are unofficially available (Lot)
			WITH BT-13(d)-Lot DISPLAY #{field|name|BT-13(d)-Lot}: ${BT-13(d)-Lot} ${BT-13(t)-Lot} ; // Deadline for requesting additional information (Lot)
			WITH BT-137-Lot[BT-615-Lot is present] DISPLAY #{field|name|BT-615-Lot}: ${distinct-values(for text:$url in BT-615-Lot return $url)}; // Information about restricted documents is available at (Lot) 
			WITH BT-137-Lot[BT-15-Lot is present] DISPLAY #{field|name|BT-15-Lot}: ${distinct-values(for text:$url in BT-15-Lot return $url)}; // Information about non-restricted documents is available at (Lot) 
			0 WITH BT-137-Lot[(BT-632-Lot is present) or (BT-124-Lot is present)] DISPLAY #{auxiliary|text|adhoc-communication}:; // Ad hoc communication channel
				WITH BT-632-Lot DISPLAY #{name}: $value; // Tool Name (Lot)
				WITH BT-124-Lot DISPLAY #{name}: $value; // Tool Atypical URL (Lot)
		12 WITH ND-Lot[(BT-631-Lot is present) or (BT-130-Lot is present) or (BT-578-Lot == 'true') or (BT-732-Lot is present) or (BT-78-Lot is present) or (BT-42-Lot is present) or (BT-46-Lot is present) or (BT-47-Lot is present) or (BT-644-Lot is present) or (BT-44-Lot is present) or (BT-41-Lot == TRUE) or (BT-45-Lot is present) or (BT-651-Lot is present) or (BT-17-Lot is present) or (BT-18-Lot is present) or (BT-19-Lot is present) or (BT-745-Lot is present) or (BT-97-Lot is present) or (BT-764-Lot is present) or (BT-744-Lot == 'true') or (BT-63-Lot is present) or (BT-769-Lot is present) or (BT-75-Lot is present) or (BT-630(d)-Lot is present) or (BT-1311(d)-Lot is present) or (BT-131(d)-Lot is present) or (BT-98-Lot is present) or ((BT-771-Lot is present) and (BT-772-Lot is present)) or (BT-132(d)-Lot is present) or (BT-133-Lot is present) or (BT-134-Lot is present) or (BT-736-Lot is present) or (BT-70-Lot is present) or (BT-801-Lot is present) or (BT-743-Lot is present) or (BT-92-Lot is present) or (BT-93-Lot is present) or (BT-76-Lot is present) or (BT-77-Lot is present) or (BT-65-Lot is present) or (BT-64-Lot is present) or (BT-729-Lot is present) or (BT-681-Lot == 'true') or (OPP-020-Contract is present) or (BT-684-Lot == 'true')] DISPLAY #{auxiliary|text|procurement-terms}; // 5.1.12 Procurement terms
			0 WITH BT-137-Lot[(BT-631-Lot is present) or (BT-130-Lot is present) or (BT-578-Lot == 'true') or (BT-732-Lot is present) or (BT-78-Lot is present)] DISPLAY #{auxiliary|text|procedure-terms}:; // Terms of the procedure
				WITH BT-631-Lot DISPLAY #{name}: $value; // Dispatch Invitation Interest
				WITH BT-130-Lot DISPLAY #{name}: $value; // Dispatch Invitation Tender
				WITH BT-578-Lot[BT-578-Lot == 'true'] DISPLAY #{name}; // A security clearance is required. (true/false)
